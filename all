# ==============================================================================
# Pareto front + combined score (MR and BMR simultaneously minimized)
# ==============================================================================

def pareto_front(agg):
    """
    Return conditions on the Pareto front w.r.t. mean_MR and mean_BMR.
    Condition A is dominated by B if B.MR <= A.MR and B.BMR <= A.BMR
    (with at least one strict inequality).
    Non-dominated conditions form the Pareto front.
    """
    mr  = agg["mean_MR"].values
    bmr = agg["mean_BMR"].values
    n   = len(agg)
    is_pareto = np.ones(n, dtype=bool)
    for i in range(n):
        if not is_pareto[i]:
            continue
        for j in range(n):
            if i == j:
                continue
            # does j dominate i?
            if mr[j] <= mr[i] and bmr[j] <= bmr[i] and (mr[j] < mr[i] or bmr[j] < bmr[i]):
                is_pareto[i] = False
                break
    return agg[is_pareto].copy()


def combined_score(agg, w_mr=0.5, w_bmr=0.5):
    """
    Normalize MR and BMR each to [0,1] then compute weighted sum.
    Lower score = better on both metrics simultaneously.
    """
    mr_min,  mr_max  = agg["mean_MR"].min(),  agg["mean_MR"].max()
    bmr_min, bmr_max = agg["mean_BMR"].min(), agg["mean_BMR"].max()
    mr_range  = mr_max  - mr_min  if mr_max  > mr_min  else 1.0
    bmr_range = bmr_max - bmr_min if bmr_max > bmr_min else 1.0
    result = agg.copy()
    result["norm_MR"]        = (agg["mean_MR"]  - mr_min)  / mr_range
    result["norm_BMR"]       = (agg["mean_BMR"] - bmr_min) / bmr_range
    result["combined_score"] = w_mr * result["norm_MR"] + w_bmr * result["norm_BMR"]
    return result.sort_values("combined_score").reset_index(drop=True)


def cond_label(row):
    sc = "on" if row["size_correction"] else "off"
    return f"K={int(row['k'])},sc={sc},t={int(row['update_type'])}"


