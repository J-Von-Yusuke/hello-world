def run_one_trace(meta_trace, trace: str, out_dir: str, w_mr: float = 0.5, w_bmr: float = 0.5):
    """Run analysis for one trace."""
    print(f"\n{'='*70}")
    print(f"  Trace: {trace}  ({len(meta_trace)} condition files)")
    print(f"{'='*70}")

    print("  [2/4] Loading CSVs...")
    master = build_master(meta_trace)
    print(f"  Total {len(master):,} rows (time windows x conditions)")

    print("  [3/4] Aggregating per condition...")
    agg = aggregate(master)
    agg["trace"] = trace
    agg.to_csv(os.path.join(out_dir, f"{trace}_agg.csv"),
               index=False, encoding="utf-8-sig")

    print("  [4/4] Generating graphs...")
    plot_ma_convergence(agg,     out_dir, trace)   # fig0
    plot_effective_mismatch(agg, out_dir, trace)   # fig1
    plot_k_curves(agg,           out_dir, trace)   # fig2
    plot_size_correction(agg,    out_dir, trace)   # fig3
    plot_pareto(agg,             out_dir, trace)   # fig4: Pareto + combined ranking

    # Add combined score to agg CSV
    scored = combined_score(agg, w_mr=w_mr, w_bmr=w_bmr)
    scored.to_csv(os.path.join(out_dir, f"{trace}_agg.csv"),
                  index=False, encoding="utf-8-sig")

    print_summary(agg, trace)
    print_pareto_summary(agg, trace, w_mr=w_mr, w_bmr=w_bmr)

    print(f"\n  Done. Output:")
    print(f"     {trace}_fig0_ma_convergence.png")
    print(f"     {trace}_fig1_effective_mismatch.png  <- core figure (MR + BMR)")
    print(f"     {trace}_fig2_optimal_k.png")
    print(f"     {trace}_fig3_size_correction.png")
    print(f"     {trace}_fig4_pareto_combined.png     <- Pareto + combined ranking")
    print(f"     {trace}_agg.csv  (includes norm_MR, norm_BMR, combined_score)")

    return agg



def main():
    parser = argparse.ArgumentParser(
        description="All-condition analysis (SIZEDIVIDE format)",
    )
    parser.add_argument("--dir",   required=True, help="Directory containing CSVs")
    parser.add_argument("--trace", default=None,
                        help="Only process files whose trace prefix matches this value "
                             "(e.g. mrsBlk-0.3).")
    parser.add_argument("--label", default=None,
                        help="Output filename prefix when combining all CSVs "
                             "(default: directory name).")
    parser.add_argument("--split-traces", action="store_true",
                        help="Auto-detect trace prefixes and process each separately. "
                             "Default: all CSVs combined into one analysis.")
    parser.add_argument("--out",   default="./output", help="Output directory")
    parser.add_argument("--w-mr",  type=float, default=0.5,
                        help="Weight for MR in combined score (default 0.5).")
    parser.add_argument("--w-bmr", type=float, default=0.5,
                        help="Weight for BMR in combined score (default 0.5).")
    args = parser.parse_args()

    os.makedirs(args.out, exist_ok=True)

    total_w = args.w_mr + args.w_bmr
    w_mr  = args.w_mr  / total_w
    w_bmr = args.w_bmr / total_w

    print("[1/4] Scanning CSVs...")
    meta = collect_csvs(args.dir)
    all_traces = sorted(meta["trace"].unique())

    if args.split_traces:
        # Mode: process each trace prefix separately
        target_traces = all_traces
        if args.trace:
            if args.trace not in all_traces:
                raise ValueError(f"Trace '{args.trace}' not found. Available: {all_traces}")
            target_traces = [args.trace]
        print(f"  Split mode: {len(target_traces)} trace(s)")
        print(f"  Weights: MR={w_mr:.2f}  BMR={w_bmr:.2f}")
        all_agg = []
        for trace in target_traces:
            meta_trace = meta[meta["trace"] == trace].copy()
            agg = run_one_trace(meta_trace, trace, args.out, w_mr=w_mr, w_bmr=w_bmr)
            all_agg.append(agg)
        if len(all_agg) > 1:
            combined = pd.concat(all_agg, ignore_index=True)
            out_p = os.path.join(args.out, "all_traces_agg.csv")
            combined.to_csv(out_p, index=False, encoding="utf-8-sig")
            print(f"  Cross-trace aggregate: {out_p}")
    else:
        # Default: combine all (or filtered) CSVs into one analysis
        if args.trace:
            if args.trace not in all_traces:
                raise ValueError(f"Trace '{args.trace}' not found. Available: {all_traces}")
            meta_use = meta[meta["trace"] == args.trace].copy()
            label = args.label or args.trace
        else:
            meta_use = meta.copy()
            label = args.label or Path(args.dir).name
        n = meta_use["trace"].nunique()
        if n > 1:
            print(f"  Combining {n} trace prefix(es) -> label='{label}'")
        print(f"  Weights: MR={w_mr:.2f}  BMR={w_bmr:.2f}")
        run_one_trace(meta_use, label, args.out, w_mr=w_mr, w_bmr=w_bmr)

    print(f"\nAll done. Output: {args.out}/")


if __name__ == "__main__":
    main()
