def run_prediction(meta, label, out_dir,
                   target="combined", w_mr=0.5, w_bmr=0.5, max_depth=4):
    """
    Train prediction models using aligned per-window features.

    target: "mr" | "bmr" | "combined" | "pareto"
      mr       -> label = condition minimising MR at each window
      bmr      -> label = condition minimising BMR at each window
      combined -> label = condition minimising w_mr*norm_MR + w_bmr*norm_BMR
      pareto   -> label = Pareto-front representative at each window

    Returns dict with result_k, result_sc, result_ut, feature_names_used, aligned_df.
    """
    print(f"\n  [1/6] Building aligned per-window feature matrix...")
    aligned_df = build_aligned_feature_matrix(meta, target=target,
                                              w_mr=w_mr, w_bmr=w_bmr)
    if aligned_df.empty:
        print("  [skip] No valid data.")
        return {}

    feat_path = os.path.join(out_dir, f"{label}_aligned_features.csv")
    aligned_df.to_csv(feat_path, index=False, encoding="utf-8-sig")
    print(f"  Saved: {feat_path}  ({len(aligned_df)} window samples)")

    if target == "pareto":
        lbl_k, lbl_sc, lbl_ut = "pareto_K", "pareto_sc", "pareto_update_type"
    else:
        lbl_k, lbl_sc, lbl_ut = "optimal_K", "optimal_sc", "optimal_update_type"

    fn_used = [f for f in WINDOW_FEATURE_NAMES if f in aligned_df.columns]
    X = aligned_df[fn_used].values.astype(float)
    col_means = np.nanmean(X, axis=0)
    inds = np.where(np.isnan(X))
    X[inds] = np.take(col_means, inds[1])

    # groups for temporally-correct CV (one group = one trace)
    groups = aligned_df["trace"].values if aligned_df["trace"].nunique() >= 2 else None

    print(f"  [2/6] Predict {lbl_k} (target={target}, n={len(X)})...")
    y_k      = aligned_df[lbl_k].values.astype(int)
    result_k = train_and_evaluate(X, y_k, fn_used, lbl_k, max_depth, groups=groups)
    print(f"         accuracy = {result_k['accuracy']:.1%}  cv={result_k['cv_strategy']}")
    print(result_k["report"])

    print(f"  [3/6] Predict {lbl_sc}...")
    y_sc      = aligned_df[lbl_sc].values.astype(int)
    result_sc = train_and_evaluate(X, y_sc, fn_used, lbl_sc, max_depth, groups=groups)
    print(f"         accuracy = {result_sc['accuracy']:.1%}  cv={result_sc['cv_strategy']}")
    print(result_sc["report"])

    print(f"  [4/6] Predict {lbl_ut}...")
    y_ut      = aligned_df[lbl_ut].values.astype(int)
    result_ut = train_and_evaluate(X, y_ut, fn_used, lbl_ut, max_depth, groups=groups)
    print(f"         accuracy = {result_ut['accuracy']:.1%}  cv={result_ut['cv_strategy']}")
    print(result_ut["report"])

    print(f"\n  [5/6] Error analysis...")
    errors_k  = analyze_errors(aligned_df, y_k,  result_k["y_pred"],
                               fn_used, result_k["importances"],  lbl_k)
    errors_sc = analyze_errors(aligned_df, y_sc, result_sc["y_pred"],
                               fn_used, result_sc["importances"], lbl_sc)
    errors_ut = analyze_errors(aligned_df, y_ut, result_ut["y_pred"],
                               fn_used, result_ut["importances"], lbl_ut)
    print(f"         K           errors: {len(errors_k)}  / {len(y_k)}")
    print(f"         sc          errors: {len(errors_sc)} / {len(y_sc)}")
    print(f"         update_type errors: {len(errors_ut)} / {len(y_ut)}")

    print(f"\n  [6/6] Saving plots and reports...")
    plot_prediction_result(aligned_df, y_k,  result_k,  lbl_k,  out_dir, label)
    plot_prediction_result(aligned_df, y_sc, result_sc, lbl_sc, out_dir, label)
    plot_prediction_result(aligned_df, y_ut, result_ut, lbl_ut, out_dir, label)
    plot_error_analysis(aligned_df, errors_k, errors_sc,
                        result_k["importances"], result_sc["importances"],
                        out_dir, label)

    ut_rpath = os.path.join(out_dir, f"{label}_update_type_rules.txt")
    with open(ut_rpath, "w", encoding="utf-8") as fh:
        fh.write(f"{lbl_ut} prediction rules  |  accuracy={result_ut['accuracy']:.1%}\n")
        fh.write("=" * 60 + "\n")
        fh.write(result_ut["rules_text"])
        fh.write("\n\n" + recommend_update_strategy())
    print(f"  Saved: {ut_rpath}")

    print(f"\n  Summary ({label}):")
    for lbl_name, res in [(lbl_k, result_k), (lbl_sc, result_sc), (lbl_ut, result_ut)]:
        print(f"    {lbl_name:<30} accuracy={res['accuracy']:.1%}  "
              f"top_feat={res['importances'].idxmax()}")

    return {
        "result_k":           result_k,
        "result_sc":          result_sc,
        "result_ut":          result_ut,
        "feature_names_used": fn_used,
        "aligned_df":         aligned_df,
        "target":             target,
        "w_mr":               w_mr,
        "w_bmr":              w_bmr,
    }


def main():
    parser = argparse.ArgumentParser(
        description="Aligned per-window prediction: optimal K / sc / update_type",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent("""
        Examples:
          # Teacher + experiment split (hardcoded lists)
          python predict_optimal_params.py --dir ./results --out ./output

          # CLI override of trace lists
          python predict_optimal_params.py --dir ./results \\
              --teacher wiki2019 twitter --experiment cachelib_cdn01

          # BMR-only target
          python predict_optimal_params.py --dir ./results --target bmr

          # Pareto-optimal label
          python predict_optimal_params.py --dir ./results --target pareto

          # Weighted combined (MR=70%, BMR=30%)
          python predict_optimal_params.py --dir ./results --target combined \\
              --w-mr 0.7 --w-bmr 0.3
        """),
    )
    parser.add_argument("--dir",        required=True)
    parser.add_argument("--out",        default="./output")
    parser.add_argument("--target",     default="combined",
                        choices=["mr", "bmr", "combined", "pareto"])
    parser.add_argument("--w-mr",       type=float, default=0.5)
    parser.add_argument("--w-bmr",      type=float, default=0.5)
    parser.add_argument("--trace",      default=None)
    parser.add_argument("--split-traces", action="store_true")
    parser.add_argument("--label",      default=None)
    parser.add_argument("--max-depth",  type=int, default=4)
    parser.add_argument("--teacher",    nargs="*", default=None, metavar="TRACE")
    parser.add_argument("--experiment", nargs="*", default=None, metavar="TRACE")
    args = parser.parse_args()

    os.makedirs(args.out, exist_ok=True)
    total_w = args.w_mr + args.w_bmr
    w_mr  = args.w_mr  / total_w
    w_bmr = args.w_bmr / total_w

    print("[1/3] Scanning CSVs...")
    meta = collect_csvs(args.dir)
    all_traces = sorted(meta["trace"].unique())
    print(f"  {len(meta)} files, traces={all_traces}")

    teacher_list    = args.teacher    if args.teacher    is not None else TEACHER_TRACES
    experiment_list = args.experiment if args.experiment is not None else EXPERIMENT_TRACES
    has_split = bool(teacher_list) or bool(experiment_list)

    if has_split:
        if not teacher_list:
            teacher_list    = [t for t in all_traces if t not in experiment_list]
        if not experiment_list:
            experiment_list = [t for t in all_traces if t not in teacher_list]
        overlap = set(teacher_list) & set(experiment_list)
        if overlap:
            print(f"  [warning] Overlap between teacher/experiment: {overlap}")

        print(f"\n[2/3] Teacher phase: {teacher_list}")
        meta_teacher = meta[meta["trace"].isin(teacher_list)].copy()
        if meta_teacher.empty:
            raise ValueError(f"Teacher traces not found: {teacher_list}")
        label_teacher = args.label or f"{Path(args.dir).name}_teacher"
        trained = run_prediction(
            meta_teacher, label_teacher, args.out,
            target=args.target, w_mr=w_mr, w_bmr=w_bmr,
            max_depth=args.max_depth,
        )
        if not trained:
            print("  [error] Teacher phase failed.")
            return

        print(f"\n[3/3] Experiment phase: {experiment_list}")
        meta_exp = meta[meta["trace"].isin(experiment_list)].copy()
        if meta_exp.empty:
            print(f"  [warning] Experiment traces not found: {experiment_list}")
        else:
            label_exp = args.label or f"{Path(args.dir).name}_experiment"
            predict_for_experiment_traces(
                experiment_meta    = meta_exp,
                result_k           = trained["result_k"],
                result_sc          = trained["result_sc"],
                result_ut          = trained["result_ut"],
                feature_names_used = trained["feature_names_used"],
                out_dir            = args.out,
                label              = label_exp,
                target             = trained["target"],
                w_mr               = trained["w_mr"],
                w_bmr              = trained["w_bmr"],
            )

            # ── Auto Pareto pass (runs when target != "pareto") ─────────────
            if trained["target"] != "pareto":
                print(f"\n[Auto-Pareto] Re-running teacher phase with target=pareto...")
                label_teacher_p = (args.label or f"{Path(args.dir).name}_teacher") + "_pareto"
                trained_p = run_prediction(
                    meta_teacher, label_teacher_p, args.out,
                    target="pareto", w_mr=0.5, w_bmr=0.5,
                    max_depth=args.max_depth,
                )
                if trained_p:
                    print(f"[Auto-Pareto] Running experiment phase with pareto models...")
                    label_exp_p = (args.label or f"{Path(args.dir).name}_experiment") + "_pareto"
                    predict_for_experiment_traces(
                        experiment_meta    = meta_exp,
                        result_k           = trained_p["result_k"],
                        result_sc          = trained_p["result_sc"],
                        result_ut          = trained_p["result_ut"],
                        feature_names_used = trained_p["feature_names_used"],
                        out_dir            = args.out,
                        label              = label_exp_p,
                        target             = "pareto",
                        w_mr               = 0.5,
                        w_bmr              = 0.5,
                    )
    else:
        print("\n[2/3] Standard mode (no teacher/experiment split)...")
        if args.split_traces:
            tgt = [args.trace] if args.trace else all_traces
            for tr in tgt:
                mt = meta[meta["trace"] == tr].copy()
                run_prediction(mt, tr, args.out,
                               target=args.target, w_mr=w_mr, w_bmr=w_bmr,
                               max_depth=args.max_depth)
        else:
            if args.trace:
                meta = meta[meta["trace"] == args.trace].copy()
            lbl = args.label or Path(args.dir).name
            run_prediction(meta, lbl, args.out,
                           target=args.target, w_mr=w_mr, w_bmr=w_bmr,
                           max_depth=args.max_depth)

    print(f"\nAll done. Output: {args.out}/")


if __name__ == "__main__":
    main()
