# ══════════════════════════════════════════════════════════════════════════════
# 性能指標の読み込みと最適条件の決定
# ══════════════════════════════════════════════════════════════════════════════

def load_performance(filepath: str) -> tuple[float, float] | None:
    """(mean_MR, mean_BMR) を返す"""
    try:
        df = pd.read_csv(filepath)
        df.columns = df.columns.str.strip().str.lower()
        mr  = df["miss_ratio"].mean()
        bmr = df["miss_byte_ratio"].mean()
        return float(mr), float(bmr)
    except Exception as e:
        print(f"  [性能読込エラー] {filepath}: {e}")
        return None


def combined_score_val(mr: float, bmr: float,
                       mr_min: float, mr_max: float,
                       bmr_min: float, bmr_max: float,
                       w_mr: float = 0.5, w_bmr: float = 0.5) -> float:
    mr_r  = mr_max  - mr_min  if mr_max  > mr_min  else 1.0
    bmr_r = bmr_max - bmr_min if bmr_max > bmr_min else 1.0
    return w_mr * (mr - mr_min) / mr_r + w_bmr * (bmr - bmr_min) / bmr_r


def determine_targets(meta: pd.DataFrame,
                      target: str = "combined",
                      w_mr: float = 0.5, w_bmr: float = 0.5) -> pd.DataFrame:
    """
    各 CSVの性能を読み込み、以下の2つの予測ターゲットを追加する。

    optimal_K:
        同じ (trace, update_type, size_correction) 内で
        最も性能が良い K の値

    optimal_sc:
        同じ (trace, update_type, k) 内で
        最も性能が良い size_correction の値 (0 or 1)

    target: "mr" | "bmr" | "combined"
    """
    perf_rows = []
    for _, row in meta.iterrows():
        result = load_performance(row["filepath"])
        if result is None:
            continue
        mr, bmr = result
        perf_rows.append({**row.to_dict(), "mean_MR": mr, "mean_BMR": bmr})

    if not perf_rows:
        raise ValueError("有効な性能データが取得できませんでした。")

    df = pd.DataFrame(perf_rows)

    # グローバル正規化（combined score 計算用）
    mr_min, mr_max   = df["mean_MR"].min(),  df["mean_MR"].max()
    bmr_min, bmr_max = df["mean_BMR"].min(), df["mean_BMR"].max()

    if target == "mr":
        df["_score"] = df["mean_MR"]      # 小さいほど良い
    elif target == "bmr":
        df["_score"] = df["mean_BMR"]
    else:
        df["_score"] = df.apply(
            lambda r: combined_score_val(
                r["mean_MR"], r["mean_BMR"],
                mr_min, mr_max, bmr_min, bmr_max, w_mr, w_bmr
            ), axis=1
        )

    # ── optimal_K: (trace, update_type, size_correction) ごとに最良K ───
    grp_k = df.groupby(["trace", "update_type", "size_correction"])
    opt_k = grp_k.apply(
        lambda g: int(g.loc[g["_score"].idxmin(), "k"])
    ).reset_index(name="optimal_K")
    df = df.merge(opt_k, on=["trace", "update_type", "size_correction"])

    # ── optimal_sc: (trace, update_type, k) ごとに最良sc ───────────────
    grp_sc = df.groupby(["trace", "update_type", "k"])
    opt_sc = grp_sc.apply(
        lambda g: int(g.loc[g["_score"].idxmin(), "size_correction"])
    ).reset_index(name="optimal_sc")
    df = df.merge(opt_sc, on=["trace", "update_type", "k"])

    # ── optimal_update_type: (trace, k, size_correction) ごとに最良update_type
    grp_ut = df.groupby(["trace", "k", "size_correction"])
    opt_ut = grp_ut.apply(
        lambda g: int(g.loc[g["_score"].idxmin(), "update_type"])
    ).reset_index(name="optimal_update_type")
    df = df.merge(opt_ut, on=["trace", "k", "size_correction"])

    return df


