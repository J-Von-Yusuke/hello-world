def recommend_update_strategy():
    """Return Parallel Shadow + Deferred Commit strategy description."""
    return "\n".join([
        "=" * 63,
        " Update Strategy: Parallel Shadow + Deferred Commit",
        "=" * 63,
        "",
        f"Phase 1  [Observation: first {SHADOW_OBSERVATION_WINDOWS} windows]",
        "-" * 63,
        "  Run all 4 update_types (-1,0,1,2) in shadow (no commit).",
        "  Record js_effective for each type per window.",
        "  WMA history is pre-warmed during this phase.",
        "  ML model predicts K and sc from workload features.",
        "",
        f"Phase 2  [Decision: at window {SHADOW_OBSERVATION_WINDOWS}]",
        "-" * 63,
        "  Commit the type with minimum mean(js_effective).",
        "  Apply ML-predicted K and sc.",
        "",
        f"Phase 3  [Operation: window {SHADOW_OBSERVATION_WINDOWS}+]",
        "-" * 63,
        "  Settings remain fixed (no frequent changes).",
        f"  Re-evaluate if |js_inherent_delta| > {DRIFT_REEVAL_THRESHOLD:.2f} for M windows.",
        "  If triggered, repeat Phase 1 (pre-warm WMA again).",
        "",
        "Advantages:",
        "  - WMA history problem solved by pre-warming in Phase 1.",
        "  - Hysteresis prevents short-term noise instability.",
        "  - Set-and-forget policy ensures cache stability.",
        "=" * 63,
    ])




def predict_for_experiment_traces(
        experiment_meta,
        result_k, result_sc, result_ut,
        feature_names_used,
        out_dir, label,
        target="combined", w_mr=0.5, w_bmr=0.5,
):
    """
    Online evaluation for experiment traces.

    Core idea:
      - Load ALL condition CSV files for each experiment trace (K x sc x update_type).
      - At each window t:
          * Ground truth  = best (K, sc, update_type) at t
                            (determined across all conditions, same as teacher phase)
          * Prediction    = model output using features from window t-1
                            (simulates real-time decision: what to use next window?)
      - Compare prediction vs ground truth => classification accuracy + REGRET.

    Regret (MR/BMR) at window t:
      regret_mr  = MR(predicted_config_at_t)  - MR(best_config_at_t)  >= 0
      regret_bmr = BMR(predicted_config_at_t) - BMR(best_config_at_t) >= 0

    Baselines included for comparison:
      Lag-1 : use optimal(t-1) as prediction for t (assumes config is stable)
      Majority: always predict the most frequent optimal config in this trace

    Note on distribution shapes:
      For the same (sc, update_type), view_counts_make evolves identically
      regardless of K (K only shifts threshold positions).
      So the 2 x 4 = 8 shape families are correctly captured across conditions.
    """
    # Step 1: build aligned ground-truth matrix + raw per-condition performance
    aligned_df, perf_matrix = build_aligned_feature_matrix(
        experiment_meta, target=target, w_mr=w_mr, w_bmr=w_bmr, return_perf=True
    )
    if aligned_df.empty:
        print("  [warning] No valid experiment trace windows.")
        return pd.DataFrame()

    if target == "pareto":
        lbl_k, lbl_sc, lbl_ut = "pareto_K", "pareto_sc", "pareto_update_type"
    else:
        lbl_k, lbl_sc, lbl_ut = "optimal_K", "optimal_sc", "optimal_update_type"

    def _pred(res):
        if res.get("model") is None:
            return None, np.nan
        proba = res["model"].predict_proba(x_vec)[0]
        idx   = int(np.argmax(proba))
        val   = int(res["le"].inverse_transform([idx])[0])
        return val, float(proba[idx])

    rows = []
    for trace_name, grp in aligned_df.groupby("trace"):
        grp  = grp.sort_values("window").reset_index(drop=True)
        T    = len(grp)
        tpm  = perf_matrix.get(trace_name, {})

        # Majority baseline: most frequent optimal config across all windows
        maj_k  = int(pd.Series(grp[lbl_k].values).mode()[0])
        maj_sc = int(pd.Series(grp[lbl_sc].values).mode()[0])
        maj_ut = int(pd.Series(grp[lbl_ut].values).mode()[0])

        for t in range(1, T):
            # ── features at t-1 (observed before deciding for t) ────────────
            feat_prev = {fn: grp.loc[t - 1, fn]
                         for fn in feature_names_used if fn in grp.columns}
            x_vec = np.array(
                [feat_prev.get(fn, 0.0) for fn in feature_names_used],
                dtype=float,
            ).reshape(1, -1)
            x_vec[np.isnan(x_vec)] = 0.0

            pk,  ck  = _pred(result_k)
            psc, csc = _pred(result_sc)
            put, cut = _pred(result_ut)

            # ── ground truth at t ───────────────────────────────────────────
            true_k  = int(grp.loc[t, lbl_k])
            true_sc = int(grp.loc[t, lbl_sc])
            true_ut = int(grp.loc[t, lbl_ut])

            # ── actual performance at window t ──────────────────────────────
            perf_at_t   = tpm.get(t, {})
            true_key    = (true_k, true_sc, true_ut)
            best_mr     = perf_at_t.get(true_key, {}).get("mr",  np.nan)
            best_bmr    = perf_at_t.get(true_key, {}).get("bmr", np.nan)

            # ML model regret
            pred_key    = (pk, psc, put) if None not in (pk, psc, put) else None
            chosen_mr   = perf_at_t.get(pred_key, {}).get("mr",  np.nan) if pred_key else np.nan
            chosen_bmr  = perf_at_t.get(pred_key, {}).get("bmr", np.nan) if pred_key else np.nan
            regret_mr   = float(chosen_mr  - best_mr)  if not (np.isnan(chosen_mr)  or np.isnan(best_mr))  else np.nan
            regret_bmr  = float(chosen_bmr - best_bmr) if not (np.isnan(chosen_bmr) or np.isnan(best_bmr)) else np.nan

            # Rank of predicted config among all conditions at window t (1 = best)
            valid_mrs = {k: v.get("mr", np.nan) for k, v in perf_at_t.items()
                         if not np.isnan(v.get("mr", np.nan))}
            n_conditions = len(valid_mrs)
            if pred_key and pred_key in valid_mrs and n_conditions > 0:
                sorted_keys = sorted(valid_mrs, key=lambda k: valid_mrs[k])
                rank_of_predicted = int(sorted_keys.index(pred_key)) + 1
                pct_rank = float(rank_of_predicted) / n_conditions
                mr_gap_to_best = float(valid_mrs[pred_key] - valid_mrs[sorted_keys[0]])
            else:
                rank_of_predicted = np.nan
                pct_rank          = np.nan
                mr_gap_to_best    = np.nan

            # Rank of predicted config by BMR among all conditions at window t
            valid_bmrs = {k: v.get("bmr", np.nan) for k, v in perf_at_t.items()
                          if not np.isnan(v.get("bmr", np.nan))}
            n_conditions_bmr = len(valid_bmrs)
            if pred_key and pred_key in valid_bmrs and n_conditions_bmr > 0:
                sorted_keys_bmr = sorted(valid_bmrs, key=lambda k: valid_bmrs[k])
                rank_of_predicted_bmr = int(sorted_keys_bmr.index(pred_key)) + 1
                pct_rank_bmr = float(rank_of_predicted_bmr) / n_conditions_bmr
                bmr_gap_to_best = float(valid_bmrs[pred_key] - valid_bmrs[sorted_keys_bmr[0]])
            else:
                rank_of_predicted_bmr = np.nan
                pct_rank_bmr          = np.nan
                bmr_gap_to_best       = np.nan

            # Pareto composite rank: rank by equal-weight normalized (MR+BMR)
            mr_vals_all  = {k: v.get("mr",  np.nan) for k, v in perf_at_t.items()}
            bmr_vals_all = {k: v.get("bmr", np.nan) for k, v in perf_at_t.items()}
            valid_both = [k for k in mr_vals_all
                          if not np.isnan(mr_vals_all[k]) and not np.isnan(bmr_vals_all.get(k, np.nan))]
            if len(valid_both) > 1:
                mrs_arr  = np.array([mr_vals_all[k]  for k in valid_both])
                bmrs_arr = np.array([bmr_vals_all[k] for k in valid_both])
                mr_rng  = float(mrs_arr.max()  - mrs_arr.min())  + EPSILON
                bmr_rng = float(bmrs_arr.max() - bmrs_arr.min()) + EPSILON
                composite_scores = {k: (mr_vals_all[k]  - mrs_arr.min())  / mr_rng
                                       + (bmr_vals_all[k] - bmrs_arr.min()) / bmr_rng
                                    for k in valid_both}
                sorted_pareto = sorted(composite_scores, key=lambda k: composite_scores[k])
                n_cond_pareto = len(valid_both)
                if pred_key and pred_key in composite_scores:
                    rank_pareto     = int(sorted_pareto.index(pred_key)) + 1
                    pct_rank_pareto = float(rank_pareto) / n_cond_pareto
                    pareto_gap      = float(composite_scores[pred_key]
                                            - composite_scores[sorted_pareto[0]])
                else:
                    rank_pareto = np.nan; pct_rank_pareto = np.nan; pareto_gap = np.nan
            elif len(valid_both) == 1:
                rank_pareto = 1; pct_rank_pareto = 1.0; pareto_gap = 0.0
            else:
                rank_pareto = np.nan; pct_rank_pareto = np.nan; pareto_gap = np.nan

            # Lag-1 baseline regret
            lag_k   = int(grp.loc[t - 1, lbl_k])
            lag_sc  = int(grp.loc[t - 1, lbl_sc])
            lag_ut  = int(grp.loc[t - 1, lbl_ut])
            lag_key = (lag_k, lag_sc, lag_ut)
            lag_mr  = perf_at_t.get(lag_key, {}).get("mr",  np.nan)
            lag_bmr = perf_at_t.get(lag_key, {}).get("bmr", np.nan)
            regret_mr_lag1  = float(lag_mr  - best_mr)  if not (np.isnan(lag_mr)  or np.isnan(best_mr))  else np.nan
            regret_bmr_lag1 = float(lag_bmr - best_bmr) if not (np.isnan(lag_bmr) or np.isnan(best_bmr)) else np.nan

            # Majority baseline regret
            maj_key    = (maj_k, maj_sc, maj_ut)
            maj_mr_val = perf_at_t.get(maj_key, {}).get("mr",  np.nan)
            maj_bmr_val= perf_at_t.get(maj_key, {}).get("bmr", np.nan)
            regret_mr_maj  = float(maj_mr_val  - best_mr)  if not (np.isnan(maj_mr_val)  or np.isnan(best_mr))  else np.nan
            regret_bmr_maj = float(maj_bmr_val - best_bmr) if not (np.isnan(maj_bmr_val) or np.isnan(best_bmr)) else np.nan

            rows.append({
                "trace":             trace_name,
                "window":            t,
                # ground truth at t
                "true_K":            true_k,
                "true_sc":           true_sc,
                "true_update_type":  true_ut,
                # ML prediction from t-1
                "pred_K":            pk,
                "conf_K":            ck,
                "pred_sc":           psc,
                "conf_sc":           csc,
                "pred_update_type":  put,
                "conf_update_type":  cut,
                # correctness flags (ML model)
                "hit_K":    int(pk  == true_k)  if pk  is not None else 0,
                "hit_sc":   int(psc == true_sc) if psc is not None else 0,
                "hit_ut":   int(put == true_ut) if put is not None else 0,
                "hit_all":  int(pk == true_k and psc == true_sc and put == true_ut)
                            if None not in (pk, psc, put) else 0,
                # actual performance
                "best_mr":           best_mr,
                "best_bmr":          best_bmr,
                "chosen_mr":         chosen_mr,
                "chosen_bmr":        chosen_bmr,
                # regret (ML model) — >= 0; 0 = perfect choice
                "regret_mr":         regret_mr,
                "regret_bmr":        regret_bmr,
                # ranking analysis: where does the predicted config rank?
                "rank_of_predicted": rank_of_predicted,
                "pct_rank":          pct_rank,
                "mr_gap_to_best":    mr_gap_to_best,
                "n_conditions":      n_conditions,
                # BMR ranking analysis
                "rank_of_predicted_bmr": rank_of_predicted_bmr,
                "pct_rank_bmr":          pct_rank_bmr,
                "bmr_gap_to_best":       bmr_gap_to_best,
                # Pareto composite ranking
                "rank_of_predicted_pareto": rank_pareto,
                "pct_rank_pareto":           pct_rank_pareto,
                "pareto_composite_gap":      pareto_gap,
                # lag-1 baseline
                "lag1_K":            lag_k,
                "lag1_sc":           lag_sc,
                "lag1_update_type":  lag_ut,
                "hit_all_lag1":      int(lag_k==true_k and lag_sc==true_sc and lag_ut==true_ut),
                "regret_mr_lag1":    regret_mr_lag1,
                "regret_bmr_lag1":   regret_bmr_lag1,
                # majority baseline
                "hit_all_maj":       int(maj_k==true_k and maj_sc==true_sc and maj_ut==true_ut),
                "regret_mr_maj":     regret_mr_maj,
                "regret_bmr_maj":    regret_bmr_maj,
                # t-1 features for reference
                **{fn: feat_prev.get(fn, np.nan) for fn in feature_names_used},
            })

    if not rows:
        print("  [warning] No windows with t-1 predecessor.")
        return pd.DataFrame()

    pred_df = pd.DataFrame(rows)

    # ── Step 3: build accuracy + regret report ──────────────────────────────
    def _fmt_regret(series, label):
        valid = series.dropna()
        if len(valid) == 0:
            return f"  {label}: n/a"
        return (f"  {label}: mean={valid.mean():.4f}  "
                f"median={valid.median():.4f}  "
                f"p95={valid.quantile(0.95):.4f}  "
                f"(n={len(valid)})")

    report_lines = [
        "=" * 72,
        f"  Experiment Trace Online Prediction Report  |  Label: {label}",
        f"  target={target}   evaluation: predict(t-1 features) vs best(t)",
        f"  Regret = MR(chosen_config) - MR(oracle_best)  [>= 0, lower=better]",
        "=" * 72,
        "",
        recommend_update_strategy(),
        "",
        "--- Per-Trace Results ---",
        "",
    ]

    def _mode(col, grp):
        vc = grp[col].value_counts()
        return vc.index[0] if len(vc) > 0 else None

    for trace_name, grp in pred_df.groupby("trace"):
        n = len(grp)
        rec_k  = _mode("pred_K",           grp)
        rec_sc = _mode("pred_sc",          grp)
        rec_ut = _mode("pred_update_type", grp)
        ut_lbl = UPDATE_TYPE_LABEL_EN.get(rec_ut, str(rec_ut))
        report_lines += [
            f"  Trace: {trace_name}  (n_windows={n})",
            "",
            "  Classification accuracy (predict t-1 -> best at t):",
            f"    K           : {grp['hit_K'].mean():.1%}",
            f"    sc          : {grp['hit_sc'].mean():.1%}",
            f"    update_type : {grp['hit_ut'].mean():.1%}",
            f"    all-correct : {grp['hit_all'].mean():.1%}",
            "",
            "  Regret (MR) — lower is better (0 = oracle optimal):",
            _fmt_regret(grp["regret_mr"],     "  ML model  "),
            _fmt_regret(grp["regret_mr_lag1"],"  Lag-1 BL  "),
            _fmt_regret(grp["regret_mr_maj"], "  Majority  "),
            "",
            "  Regret (BMR):",
            _fmt_regret(grp["regret_bmr"],     "  ML model  "),
            _fmt_regret(grp["regret_bmr_lag1"],"  Lag-1 BL  "),
            _fmt_regret(grp["regret_bmr_maj"], "  Majority  "),
            "",
            f"  Most-frequent prediction: K={rec_k}, sc={rec_sc}, "
            f"update_type={rec_ut} ({ut_lbl})",
            "",
            "  Ranking analysis (how useful is the prediction, even if label misses):",
            f"    median rank of predicted : {grp['rank_of_predicted'].median():.1f}"
            f"  (1 = oracle, {int(grp['n_conditions'].dropna().median()) if 'n_conditions' in grp.columns else '?'} total conditions)",
            f"    rank-1 (oracle match) rate: {(grp['rank_of_predicted']==1).mean():.1%}",
            f"    median MR gap to best    : {grp['mr_gap_to_best'].median():.4f}",
            f"    p95   MR gap to best     : {grp['mr_gap_to_best'].quantile(0.95):.4f}",
            "",
            f"  Parallel Shadow + Deferred Commit steps:",
            f"    1. Shadow all update_types for {SHADOW_OBSERVATION_WINDOWS} windows",
            f"    2. Commit type with min js_effective (ML recommends: {rec_ut})",
            f"    3. Apply K={rec_k}, sc={rec_sc} -> start normal operation",
            f"    4. Re-evaluate if js_inherent drift > {DRIFT_REEVAL_THRESHOLD:.2f}",
            "",
        ]

    # Overall
    n_total = len(pred_df)
    report_lines += [
        "--- Overall ---",
        f"  total windows evaluated: {n_total}",
        f"  all-correct  ML : {pred_df['hit_all'].mean():.1%}",
        f"  all-correct Lag1: {pred_df['hit_all_lag1'].mean():.1%}",
        f"  all-correct  Maj: {pred_df['hit_all_maj'].mean():.1%}",
        "",
        "  Mean Regret MR :",
        _fmt_regret(pred_df["regret_mr"],      "  ML model  "),
        _fmt_regret(pred_df["regret_mr_lag1"], "  Lag-1 BL  "),
        _fmt_regret(pred_df["regret_mr_maj"],  "  Majority  "),
        "",
        "  Mean Regret BMR:",
        _fmt_regret(pred_df["regret_bmr"],      "  ML model  "),
        _fmt_regret(pred_df["regret_bmr_lag1"], "  Lag-1 BL  "),
        _fmt_regret(pred_df["regret_bmr_maj"],  "  Majority  "),
        "",
    ]

    # ── Drift/margin stratification ─────────────────────────────────────────
    drift_col  = "wt_js_vs_prev"
    margin_col = "score_margin"

    if drift_col in pred_df.columns and pred_df[drift_col].notna().sum() >= 8:
        try:
            pred_df["_drift_q"] = pd.qcut(
                pred_df[drift_col], q=4,
                labels=["Q1(low-drift)", "Q2", "Q3", "Q4(high-drift)"],
                duplicates="drop",
            )
            report_lines += [
                "--- Accuracy by Distribution Drift (wt_js_vs_prev quartile) ---",
                "  (Low drift = stable; label noise risk highest here)",
                "",
            ]
            for q_lbl, qgrp in pred_df.groupby("_drift_q", observed=True):
                js_min = qgrp[drift_col].min()
                js_max = qgrp[drift_col].max()
                report_lines.append(
                    f"  {str(q_lbl):<18}  js=[{js_min:.4f},{js_max:.4f}]"
                    f"  hit_all={qgrp['hit_all'].mean():.1%}"
                    f"  regret_mr={qgrp['regret_mr'].mean():.4f}"
                    f"  n={len(qgrp)}"
                )
            pred_df.drop(columns=["_drift_q"], inplace=True)
            report_lines.append("")
        except Exception as e:
            report_lines.append(f"  [drift stratification skipped: {e}]")
            report_lines.append("")

    if margin_col in pred_df.columns and pred_df[margin_col].notna().sum() >= 8:
        try:
            pred_df["_margin_q"] = pd.qcut(
                pred_df[margin_col], q=4,
                labels=["Q1(tight-margin)", "Q2", "Q3", "Q4(clear-margin)"],
                duplicates="drop",
            )
            report_lines += [
                "--- Accuracy by Score Margin (label reliability) ---",
                "  (Tight margin = best/2nd-best conditions nearly equal)",
                "",
            ]
            for q_lbl, qgrp in pred_df.groupby("_margin_q", observed=True):
                m_min = qgrp[margin_col].min()
                m_max = qgrp[margin_col].max()
                report_lines.append(
                    f"  {str(q_lbl):<22}  margin=[{m_min:.4f},{m_max:.4f}]"
                    f"  hit_all={qgrp['hit_all'].mean():.1%}"
                    f"  regret_mr={qgrp['regret_mr'].mean():.4f}"
                    f"  n={len(qgrp)}"
                )
            pred_df.drop(columns=["_margin_q"], inplace=True)
            report_lines.append("")
        except Exception as e:
            report_lines.append(f"  [margin stratification skipped: {e}]")
            report_lines.append("")

    report_lines.append("=" * 72)

    rpath = os.path.join(out_dir, f"{label}_experiment_predictions.txt")
    with open(rpath, "w", encoding="utf-8") as fh:
        fh.write("\n".join(report_lines))
    print(f"  Saved: {rpath}")

    cpath = os.path.join(out_dir, f"{label}_experiment_predictions.csv")
    pred_df.to_csv(cpath, index=False, encoding="utf-8-sig")
    print(f"  Saved: {cpath}")

    _plot_experiment_accuracy(pred_df, out_dir, label)
    _plot_regret(pred_df, out_dir, label)
    _plot_rank_analysis(pred_df, out_dir, label)

    return pred_df



def _plot_experiment_accuracy(pred_df, out_dir, label):
    """
    Per-window hit rate plot + low-drift failure analysis scatter.

    Layout: n_tr rows x 2 columns
      Left  col: rolling-20 hit rate over time (existing)
      Right col: wt_js_vs_prev vs hit_all scatter, coloured by score_margin
                 (diagnoses whether low-drift windows cause more failures)
    """
    if pred_df.empty:
        return

    has_drift  = "wt_js_vs_prev" in pred_df.columns
    has_margin = "score_margin"   in pred_df.columns

    traces = pred_df["trace"].unique()
    n_tr   = len(traces)
    ncols  = 2 if has_drift else 1
    fig, axes = plt.subplots(n_tr, ncols,
                             figsize=(14 * ncols // 2 + 7, 3.5 * n_tr),
                             squeeze=False)

    for row_i, trace_name in enumerate(traces):
        grp = pred_df[pred_df["trace"] == trace_name].sort_values("window")
        ws  = grp["window"].values

        # ── Left: rolling hit rate ──────────────────────────────────────────
        ax_l = axes[row_i, 0]
        for col, color, lbl in [
            ("hit_K",  "#1976D2", "K"),
            ("hit_sc", "#388E3C", "sc"),
            ("hit_ut", "#F57C00", "update_type"),
            ("hit_all","#9C27B0", "all"),
        ]:
            roll = pd.Series(grp[col].values).rolling(20, min_periods=1).mean().values
            ax_l.plot(ws, roll, color=color, linewidth=1.2, label=lbl)

        ax_l.axhline(0.5, color="gray", linestyle="--", linewidth=0.8, alpha=0.6)
        ax_l.set_ylim(0, 1.05)
        ax_l.set_title(
            f"Trace: {trace_name}  |  rolling-20 hit rate (predict t-1 -> t)",
            fontsize=10,
        )
        ax_l.set_xlabel("Window t")
        ax_l.set_ylabel("Hit rate")
        ax_l.legend(fontsize=8, ncol=4)
        ax_l.grid(True, alpha=0.3)

        # ── Right: drift vs pct_rank gradient scatter ───────────────────────
        if not has_drift or ncols < 2:
            continue
        ax_r = axes[row_i, 1]

        js_vals = grp["wt_js_vs_prev"].values.astype(float)

        # Use pct_rank (continuous quality) as y-axis if available,
        # falling back to binary hit_all for older DataFrames.
        has_pct_rank = "pct_rank" in grp.columns
        if has_pct_rank:
            y_vals   = pd.to_numeric(grp["pct_rank"], errors="coerce").values.astype(float)
            y_label  = "pct_rank  (0=oracle best, 1=worst)"
            y_lim    = (-0.05, 1.1)
            c_vals   = y_vals.copy()          # colour == y
            cmap_use = "RdYlGn_r"             # green=0 (best), red=1 (worst)
            cbar_lbl = "pct_rank\n(green=oracle, red=worst)"
            vmin_c, vmax_c = 0.0, 1.0
            thresh_val   = 0.2
            thresh_label = "top-20% boundary"
        else:
            y_raw   = grp["hit_all"].values.astype(float)
            jitter  = np.random.default_rng(42).uniform(-0.03, 0.03, size=len(y_raw))
            y_vals  = y_raw + jitter
            y_label = "hit_all  (0=miss, 1=correct)"
            y_lim   = (-0.1, 1.15)
            c_vals  = grp["score_margin"].values.astype(float) if has_margin else None
            cmap_use = "RdYlGn"
            cbar_lbl = "score_margin\n(green=clear, red=tight)"
            vmin_c = np.nanpercentile(c_vals, 5)  if c_vals is not None else 0
            vmax_c = np.nanpercentile(c_vals, 95) if c_vals is not None else 1
            thresh_val   = 0.5
            thresh_label = "random baseline"

        valid = ~(np.isnan(js_vals) | np.isnan(y_vals))
        c_plot = c_vals[valid] if c_vals is not None else None

        if c_plot is not None:
            sc_obj = ax_r.scatter(
                js_vals[valid], y_vals[valid],
                c=c_plot, cmap=cmap_use,
                vmin=vmin_c, vmax=vmax_c,
                alpha=0.5, s=14, edgecolors="none",
            )
            cbar = fig.colorbar(sc_obj, ax=ax_r, pad=0.02)
            cbar.set_label(cbar_lbl, fontsize=7)
            if (~valid).any():
                ax_r.scatter(js_vals[~valid], y_vals[~valid],
                             c="lightgray", alpha=0.3, s=8, edgecolors="none")
        else:
            ax_r.scatter(js_vals[valid], y_vals[valid],
                         alpha=0.35, s=10, color="#555")

        # Trend line: binned mean of y by JS quantile
        try:
            js_s  = pd.Series(js_vals, name="wt_js_vs_prev")
            y_s   = pd.Series(y_vals,  name="y")
            both  = pd.concat([js_s, y_s], axis=1).dropna()
            bins_cut = pd.qcut(both["wt_js_vs_prev"], q=10, duplicates="drop")
            bin_x = both["wt_js_vs_prev"].groupby(bins_cut).mean().values
            bin_y = both["y"].groupby(bins_cut).mean().values
            order = np.argsort(bin_x)
            trend_lbl = "binned mean pct_rank" if has_pct_rank else "binned mean hit_all"
            ax_r.plot(bin_x[order], bin_y[order],
                      color="#1976D2", linewidth=2.0, linestyle="-",
                      label=trend_lbl, zorder=5)
        except Exception:
            pass

        ax_r.axhline(thresh_val, color="gray", linestyle="--",
                     linewidth=0.9, alpha=0.6, label=thresh_label)
        ax_r.set_ylim(*y_lim)
        ax_r.set_xlabel("wt_js_vs_prev  (distribution drift)", fontsize=9)
        ax_r.set_ylabel(y_label, fontsize=9)
        ax_r.set_title(
            f"Trace: {trace_name}  |  Drift vs Prediction Quality\n"
            "(x=drift magnitude; y/colour=pct_rank — green=near oracle, red=far)",
            fontsize=9,
        )
        ax_r.legend(fontsize=7)
        ax_r.grid(True, alpha=0.25)

    plt.suptitle(
        f"Experiment Accuracy  |  {label}\n"
        "(Right panels: drift vs pct_rank gradient — "
        "green=near oracle, red=far from oracle)",
        fontsize=10, y=1.01,
    )
    plt.tight_layout()
    fpath = os.path.join(out_dir, f"{label}_experiment_accuracy.png")
    plt.savefig(fpath, dpi=150, bbox_inches="tight")
    plt.close()
    print(f"  Saved: {fpath}")


