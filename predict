# ══════════════════════════════════════════════════════════════════════════════
# Window-based aligned feature extraction (per-window, cross-condition)
# ──────────────────────────────────────────────────────────────────────────────
# Design rationale:
#   Load ALL condition CSVs for one trace simultaneously, align by time window.
#   At each window t, compare all (K, sc, update_type) conditions and label
#   the best one. Features come from view_counts_now only (workload, not method).
#
#   Removed from features (method outcomes, not workload inputs):
#     - miss_ratio, inter_miss_ratio  -> label side
#     - mean_delta_mr_lru             -> label side
#
#   Valid workload features:
#     - view_counts_now statistics (entropy, gini, concentration)
#     - JS(view_counts_now[t-1], view_counts_now[t])  pure drift
#     - n_req, req_byte
#     - inter_miss_ratio_lru  (LRU difficulty, independent of our method)
# ══════════════════════════════════════════════════════════════════════════════

WINDOW_FEATURE_NAMES = [
    # --- shape / spread ---
    "wt_entropy", "wt_norm_entropy",
    "wt_top1_conc", "wt_top3_conc",
    "wt_gini", "wt_n_peaks", "wt_peak_bin",
    # --- drift ---
    "wt_js_vs_prev",
    # --- volume (log2-scaled) ---
    "wt_log2_n_req", "wt_log2_req_byte",
    # --- inter-window volume ratio ---
    "wt_inter_n_req", "wt_inter_req_byte",
    # --- byte distribution ---
    "wt_byte_concentration", "wt_byte_mean_size",
    # --- distribution location (which bins are active) ---
    "wt_active_min_bin", "wt_active_max_bin", "wt_active_range",
    "wt_p25_bin", "wt_p50_bin", "wt_p75_bin",
    "wt_byte_p50_bin", "wt_byte_p75_bin",
    # --- distribution moments ---
    "wt_skewness", "wt_kurtosis", "wt_bimodality",
]

WINDOW_FEATURE_EXPLANATION = {
    # shape / spread
    "wt_entropy":            "Shannon entropy of view_counts_now at this window",
    "wt_norm_entropy":       "Normalized entropy [0,1] at this window",
    "wt_top1_conc":          "Top-1 bucket concentration at this window",
    "wt_top3_conc":          "Top-3 bucket concentration at this window",
    "wt_gini":               "Gini of request distribution at this window",
    "wt_n_peaks":            "Number of local maxima in request distribution",
    "wt_peak_bin":           "Most popular size bucket index at this window",
    # drift
    "wt_js_vs_prev":         "JS(view_counts_now[t-1], view_counts_now[t]) pure workload drift",
    # volume (log2-scaled to reduce magnitude effect)
    "wt_log2_n_req":         "log2(n_req + 1): log-scaled request count",
    "wt_log2_req_byte":      "log2(req_byte + 1): log-scaled total bytes",
    # inter-window volume ratio (change rate)
    "wt_inter_n_req":        "n_req[t] / (n_req[t-1] + eps): inter-window request count ratio",
    "wt_inter_req_byte":     "req_byte[t] / (req_byte[t-1] + eps): inter-window byte ratio",
    # byte distribution
    "wt_byte_concentration": "Fraction of bytes in top-3 size buckets at this window",
    "wt_byte_mean_size":     "Byte-weighted mean bucket index at this window",
    # distribution location (WHERE in size space the distribution falls)
    "wt_active_min_bin":     "Minimum bin index with non-zero request fraction",
    "wt_active_max_bin":     "Maximum bin index with non-zero request fraction",
    "wt_active_range":       "active_max_bin - active_min_bin: effective bandwidth",
    "wt_p25_bin":            "25th percentile bin index (request CDF)",
    "wt_p50_bin":            "50th percentile bin index (request CDF)",
    "wt_p75_bin":            "75th percentile bin index (request CDF)",
    "wt_byte_p50_bin":       "50th percentile bin index (byte CDF)",
    "wt_byte_p75_bin":       "75th percentile bin index (byte CDF)",
    # distribution moments
    "wt_skewness":           "Skewness of request count distribution over bin indices",
    "wt_kurtosis":           "Excess kurtosis of request count distribution over bin indices",
    "wt_bimodality":         "Bimodality coefficient (skew^2+1)/kurtosis; >0.555 suggests bimodal",
}


def extract_single_window_features(df, t):
    """
    Extract workload features for time window t from a DataFrame.
    Uses view_counts_now (shared across all conditions) only.
    Does NOT use proposed-method outcomes or LRU miss ratios
    (those are outcome metrics, not available for online prediction).
    """
    now_cols = find_series_cols(df, "view_counts_now")
    if not now_cols or t >= len(df):
        return None

    B       = len(now_cols)
    bin_idx = np.arange(B, dtype=float)
    now_t   = df[now_cols].iloc[t].values.astype(float)
    prob_t  = to_prob(now_t)

    # ── shape / spread ────────────────────────────────────────────────────────
    ent      = float(scipy_entropy(prob_t))
    norm_ent = ent / np.log(B) if B > 1 else 0.0
    sp       = np.sort(prob_t)[::-1]
    top1     = float(sp[0])
    top3     = float(sp[:3].sum())
    gini     = gini_coeff(prob_t)
    n_pk     = count_peaks(prob_t)
    pk_bin   = int(np.argmax(prob_t))

    # ── drift ─────────────────────────────────────────────────────────────────
    if t > 0:
        now_prev = df[now_cols].iloc[t - 1].values.astype(float)
        js_prev  = js_div(to_prob(now_prev), prob_t)
    else:
        js_prev  = 0.0

    # ── volume columns ────────────────────────────────────────────────────────
    def _sc(col, row=t):
        if col in df.columns:
            return float(pd.to_numeric(df[col].iloc[row], errors="coerce"))
        return np.nan

    n_req    = _sc("n_req")
    req_byte = _sc("req_byte")

    # log2-scaled (reduces magnitude; tree splits become scale-invariant)
    log2_n_req    = float(np.log2(max(n_req,    0) + 1)) if not np.isnan(n_req)    else np.nan
    log2_req_byte = float(np.log2(max(req_byte, 0) + 1)) if not np.isnan(req_byte) else np.nan

    # inter-window ratio (captures acceleration / deceleration)
    if t > 0:
        n_req_prev    = _sc("n_req",    t - 1)
        req_byte_prev = _sc("req_byte", t - 1)
        inter_n_req    = float(n_req    / (n_req_prev    + EPSILON)) if not np.isnan(n_req)    else np.nan
        inter_req_byte = float(req_byte / (req_byte_prev + EPSILON)) if not np.isnan(req_byte) else np.nan
    else:
        inter_n_req    = 1.0
        inter_req_byte = 1.0

    # ── byte distribution ─────────────────────────────────────────────────────
    byte_w  = np.power(2.0, bin_idx)
    byte_d  = prob_t * byte_w
    byte_dn = byte_d / (byte_d.sum() + EPSILON)
    byte_t3 = float(np.sort(byte_dn)[::-1][:3].sum())
    byte_ms = float(np.dot(bin_idx, byte_dn))

    # ── distribution LOCATION (where in size space the distribution sits) ─────
    active_mask = prob_t > 0
    if active_mask.any():
        active_bins    = bin_idx[active_mask]
        active_min_bin = float(active_bins.min())
        active_max_bin = float(active_bins.max())
        active_range   = active_max_bin - active_min_bin
    else:
        active_min_bin = 0.0
        active_max_bin = 0.0
        active_range   = 0.0

    # Request CDF percentile bins
    cdf_req = np.cumsum(prob_t)
    def _percentile_bin(cdf, q):
        idx = np.searchsorted(cdf, q, side="left")
        return float(min(idx, B - 1))

    p25_bin = _percentile_bin(cdf_req, 0.25)
    p50_bin = _percentile_bin(cdf_req, 0.50)
    p75_bin = _percentile_bin(cdf_req, 0.75)

    # Byte CDF percentile bins
    cdf_byte = np.cumsum(byte_dn)
    byte_p50_bin = _percentile_bin(cdf_byte, 0.50)
    byte_p75_bin = _percentile_bin(cdf_byte, 0.75)

    # ── distribution MOMENTS (over bin indices, weighted by request prob) ─────
    mean_bin = float(np.dot(bin_idx, prob_t))
    variance = float(np.dot((bin_idx - mean_bin) ** 2, prob_t))
    std_bin  = float(np.sqrt(variance + EPSILON))

    skewness = float(np.dot(((bin_idx - mean_bin) / std_bin) ** 3, prob_t))
    kurtosis = float(np.dot(((bin_idx - mean_bin) / std_bin) ** 4, prob_t)) - 3.0  # excess

    # Bimodality coefficient: (skew^2 + 1) / kurtosis; > 0.555 suggests bimodal
    denom_bio = kurtosis + 3.0  # use raw kurtosis (= excess + 3)
    bimodality = float((skewness ** 2 + 1.0) / (abs(denom_bio) + EPSILON))

    return {
        # shape / spread
        "wt_entropy":            ent,
        "wt_norm_entropy":       norm_ent,
        "wt_top1_conc":          top1,
        "wt_top3_conc":          top3,
        "wt_gini":               gini,
        "wt_n_peaks":            n_pk,
        "wt_peak_bin":           pk_bin,
        # drift
        "wt_js_vs_prev":         js_prev,
        # volume (log2-scaled)
        "wt_log2_n_req":         log2_n_req,
        "wt_log2_req_byte":      log2_req_byte,
        # inter-window ratio
        "wt_inter_n_req":        inter_n_req,
        "wt_inter_req_byte":     inter_req_byte,
        # byte distribution
        "wt_byte_concentration": byte_t3,
        "wt_byte_mean_size":     byte_ms,
        # distribution location
        "wt_active_min_bin":     active_min_bin,
        "wt_active_max_bin":     active_max_bin,
        "wt_active_range":       active_range,
        "wt_p25_bin":            p25_bin,
        "wt_p50_bin":            p50_bin,
        "wt_p75_bin":            p75_bin,
        "wt_byte_p50_bin":       byte_p50_bin,
        "wt_byte_p75_bin":       byte_p75_bin,
        # distribution moments
        "wt_skewness":           skewness,
        "wt_kurtosis":           kurtosis,
        "wt_bimodality":         bimodality,
    }


def compute_pareto_front(perf_dict):
    """
    Given {key: {"mr": float, "bmr": float}},
    return keys on the Pareto front (not dominated in MR+BMR space).
    key_j dominates key_i iff mr_j<=mr_i AND bmr_j<=bmr_i AND at least one <.
    """
    valid = {k: v for k, v in perf_dict.items()
             if not (np.isnan(v.get("mr", np.nan)) or np.isnan(v.get("bmr", np.nan)))}
    dominated = set()
    keys = list(valid.keys())
    for ki in keys:
        vi = valid[ki]
        for kj in keys:
            if ki == kj:
                continue
            vj = valid[kj]
            if (vj["mr"] <= vi["mr"] and vj["bmr"] <= vi["bmr"] and
                    (vj["mr"] < vi["mr"] or vj["bmr"] < vi["bmr"])):
                dominated.add(ki)
                break
    return set(keys) - dominated


def build_aligned_feature_matrix(trace_meta, target="combined", w_mr=0.5, w_bmr=0.5,
                                  return_perf: bool = False):
    """
    Build per-window samples by aligning all condition CSVs for each trace.

    Correct design for online parameter selection:
      - 1 row = (trace, time window t)
      - Features = workload state at window t (shared across all conditions)
      - Label = which (K, sc, update_type) is best at window t

    This avoids the per-file design flaw where identical workload distributions
    appear as separate (and supposedly different) training samples.

    target: "mr" | "bmr" | "combined" | "pareto"

    return_perf: if True, also return perf_matrix dict:
        {trace_name: {window_t: {(K,sc,ut): {"mr": float, "bmr": float}}}}
        Used by predict_for_experiment_traces() to compute regret.
    """
    all_rows   = []
    perf_matrix: dict = {}   # only populated when return_perf=True

    for trace_name, grp in trace_meta.groupby("trace"):
        cond_dfs = {}
        for _, row in grp.iterrows():
            key = (int(row["k"]), int(row["size_correction"]), int(row["update_type"]))
            try:
                df = pd.read_csv(row["filepath"])
                df.columns = df.columns.str.strip().str.lower()
                cond_dfs[key] = df
            except Exception as e:
                print(f"  [load error] {row['filepath']}: {e}")
        if not cond_dfs:
            continue

        if return_perf:
            perf_matrix[trace_name] = {}

        ref_df = next(
            (df for df in cond_dfs.values() if "miss_ratio_lru" in df.columns),
            list(cond_dfs.values())[0],
        )
        T = len(ref_df)

        mr_all, bmr_all = [], []
        for df in cond_dfs.values():
            if "miss_ratio"      in df.columns:
                mr_all.extend( pd.to_numeric(df["miss_ratio"],      errors="coerce").dropna())
            if "miss_byte_ratio" in df.columns:
                bmr_all.extend(pd.to_numeric(df["miss_byte_ratio"], errors="coerce").dropna())
        mr_min,  mr_max  = (float(min(mr_all)),  float(max(mr_all)))  if mr_all  else (0.0, 1.0)
        bmr_min, bmr_max = (float(min(bmr_all)), float(max(bmr_all))) if bmr_all else (0.0, 1.0)
        mr_r  = mr_max  - mr_min  if mr_max  > mr_min  else 1.0
        bmr_r = bmr_max - bmr_min if bmr_max > bmr_min else 1.0

        for t in range(T):
            wt_feat = extract_single_window_features(ref_df, t)
            if wt_feat is None:
                continue

            # ── LRU baseline: current and previous window ─────────────────
            lru_mr_t  = (float(pd.to_numeric(ref_df["miss_ratio_lru"].iloc[t],      errors="coerce"))
                         if "miss_ratio_lru"      in ref_df.columns else np.nan)
            lru_bmr_t = (float(pd.to_numeric(ref_df["miss_byte_ratio_lru"].iloc[t], errors="coerce"))
                         if "miss_byte_ratio_lru" in ref_df.columns else np.nan)
            lru_mr_t1  = (float(pd.to_numeric(ref_df["miss_ratio_lru"].iloc[t - 1],      errors="coerce"))
                          if t > 0 and "miss_ratio_lru"      in ref_df.columns else np.nan)
            lru_bmr_t1 = (float(pd.to_numeric(ref_df["miss_byte_ratio_lru"].iloc[t - 1], errors="coerce"))
                          if t > 0 and "miss_byte_ratio_lru" in ref_df.columns else np.nan)

            # Inter-window LRU ratios (how much did LRU itself change?)
            inter_lru_mr  = (lru_mr_t  / (lru_mr_t1  + EPSILON)
                             if not np.isnan(lru_mr_t1)  and lru_mr_t1  > EPSILON else np.nan)
            inter_lru_bmr = (lru_bmr_t / (lru_bmr_t1 + EPSILON)
                             if not np.isnan(lru_bmr_t1) and lru_bmr_t1 > EPSILON else np.nan)

            # Volume ratio between windows (from workload features already computed)
            # n_req_t / n_req_{t-1} removes volume-driven MR changes from the score
            vol_ratio      = float(wt_feat.get("wt_inter_n_req",    np.nan))
            vol_ratio_byte = float(wt_feat.get("wt_inter_req_byte", np.nan))

            perf_t = {}
            for key, df in cond_dfs.items():
                if t >= len(df):
                    continue
                mr  = (float(pd.to_numeric(df["miss_ratio"].iloc[t],      errors="coerce"))
                       if "miss_ratio"      in df.columns else np.nan)
                bmr = (float(pd.to_numeric(df["miss_byte_ratio"].iloc[t], errors="coerce"))
                       if "miss_byte_ratio" in df.columns else np.nan)
                mr_prev  = (float(pd.to_numeric(df["miss_ratio"].iloc[t - 1],      errors="coerce"))
                            if t > 0 and "miss_ratio"      in df.columns else np.nan)
                bmr_prev = (float(pd.to_numeric(df["miss_byte_ratio"].iloc[t - 1], errors="coerce"))
                            if t > 0 and "miss_byte_ratio" in df.columns else np.nan)
                perf_t[key] = {"mr": mr, "bmr": bmr,
                               "mr_prev": mr_prev, "bmr_prev": bmr_prev,
                               "lru_mr": lru_mr_t, "lru_bmr": lru_bmr_t}
            if not perf_t:
                continue

            # Store per-condition performance for regret calculation
            if return_perf:
                perf_matrix[trace_name][t] = dict(perf_t)

            # ── Inter-window relative scoring (LRU + volume normalised) ───
            # Score formula (3-level fallback chain):
            #  1. inter-window:  (mr_t/mr_{t-1} - lru_ratio) / lru_ratio / vol_ratio
            #     → measures how much this config's MR changed vs LRU's MR change,
            #       normalised by the request volume ratio to remove volume effects.
            #  2. LRU-absolute:  mr_t / lru_mr_t        (when t=0 or data missing)
            #  3. global-range:  (mr_t - mr_min) / mr_r  (final fallback)
            #
            # argmin(score) = config with the best performance trajectory relative
            # to the LRU baseline, independent of workload volume shifts.

            def _rel_score_1d(val, val1, i_lru, vol, lru_abs, g_min, g_r):
                if (not np.isnan(val1)  and val1  > EPSILON and
                        not np.isnan(i_lru) and i_lru > EPSILON and
                        not np.isnan(vol)   and vol   > EPSILON):
                    return ((val / (val1 + EPSILON) - i_lru) / (i_lru + EPSILON)) / vol
                if not np.isnan(lru_abs) and lru_abs > EPSILON:
                    return val / lru_abs
                return (val - g_min) / g_r

            scores = {}
            for key, v in perf_t.items():
                mr   = v["mr"];   bmr   = v["bmr"]
                mr1  = v.get("mr_prev",  np.nan)
                bmr1 = v.get("bmr_prev", np.nan)
                if np.isnan(mr) or np.isnan(bmr):
                    continue
                s_mr  = _rel_score_1d(mr,  mr1,  inter_lru_mr,  vol_ratio,
                                      lru_mr_t,  mr_min,  mr_r)
                s_bmr = _rel_score_1d(bmr, bmr1, inter_lru_bmr, vol_ratio_byte,
                                      lru_bmr_t, bmr_min, bmr_r)
                if target == "mr":
                    scores[key] = s_mr
                elif target == "bmr":
                    scores[key] = s_bmr
                else:  # "combined" or "pareto"
                    scores[key] = w_mr * s_mr + w_bmr * s_bmr
            if not scores:
                continue

            best_key          = min(scores, key=scores.get)
            opt_k, opt_sc, opt_ut = best_key

            # score_margin: now LRU-relative (scores are LRU-normalised)
            # Q1(tight) ~ 0.001 means 2nd-best is 0.1% of LRU worse than best
            sorted_scores = sorted(scores.values())
            score_margin  = float(sorted_scores[1] - sorted_scores[0]) \
                            if len(sorted_scores) >= 2 else np.nan

            pareto_keys = compute_pareto_front(perf_t)
            if pareto_keys:
                p_sc = {k: scores[k] for k in pareto_keys if k in scores}
                par_best = min(p_sc, key=p_sc.get) if p_sc else best_key
            else:
                par_best = best_key
            par_k, par_sc, par_ut = par_best

            # K-sensitivity: LRU-relative (best-MR spread across K values)
            # Dividing by LRU_MR makes this scale-invariant across traces.
            best_mr_per_k = {}
            for (kv, scv, utv), v in perf_t.items():
                mr_v = v.get("mr", np.nan)
                if np.isnan(mr_v):
                    continue
                if kv not in best_mr_per_k or mr_v < best_mr_per_k[kv]:
                    best_mr_per_k[kv] = mr_v
            if len(best_mr_per_k) >= 2:
                k_sens_abs = float(max(best_mr_per_k.values()) - min(best_mr_per_k.values()))
                k_sensitivity = (k_sens_abs / lru_mr_t
                                 if not np.isnan(lru_mr_t) and lru_mr_t > EPSILON
                                 else k_sens_abs)
            else:
                k_sensitivity = np.nan

            # M1 MR improvement: (LRU_MR - best_MR) / LRU_MR
            best_mr_val = perf_t[best_key]["mr"] if best_key in perf_t else np.nan
            m1_improvement = (float((lru_mr_t - best_mr_val) / lru_mr_t)
                              if not np.isnan(lru_mr_t) and not np.isnan(best_mr_val) and lru_mr_t > EPSILON
                              else np.nan)

            # M1 BMR improvement: (LRU_BMR - best_BMR) / LRU_BMR
            best_bmr_val = perf_t[best_key]["bmr"] if best_key in perf_t else np.nan
            m1_bmr_improvement = (float((lru_bmr_t - best_bmr_val) / lru_bmr_t)
                                  if not np.isnan(lru_bmr_t) and not np.isnan(best_bmr_val) and lru_bmr_t > EPSILON
                                  else np.nan)

            all_rows.append({
                "trace":               trace_name,
                "window":              t,
                "optimal_K":           opt_k,
                "optimal_sc":          opt_sc,
                "optimal_update_type": opt_ut,
                "pareto_K":            par_k,
                "pareto_sc":           par_sc,
                "pareto_update_type":  par_ut,
                "score_margin":        score_margin,
                "lru_mr_t":            lru_mr_t,
                "lru_bmr_t":           lru_bmr_t,
                "k_sensitivity":       k_sensitivity,
                "m1_improvement":      m1_improvement,
                "m1_bmr_improvement":  m1_bmr_improvement,
                **wt_feat,
            })

    df_out = pd.DataFrame(all_rows)
    if return_perf:
        return df_out, perf_matrix
    return df_out


