    sep = "=" * 72

    lines.append(sep)
    lines.append(f"  最適パラメータ予測レポート  |  Label: {label}")
    lines.append(f"  最適化ターゲット: {target}")
    lines.append(sep)

    lines.append("")
    lines.append("── 特徴量の説明 " + "─" * 56)
    for feat, desc in FEATURE_EXPLANATION.items():
        lines.append(f"  {feat:<25} : {desc}")

    for target_name, result, errors in [
        ("optimal_K",  result_k,  errors_k),
        ("optimal_sc", result_sc, errors_sc),
    ]:
        lines.append("")
        lines.append(f"{'─'*72}")
        lines.append(f"  【予測ターゲット: {target_name}】")
        lines.append(f"{'─'*72}")
        lines.append(f"  Leave-One-Out 交差検証精度: {result['accuracy']:.1%}")
        lines.append("")
        lines.append("  分類レポート:")
        for line in result["report"].splitlines():
            lines.append("    " + line)

        lines.append("")
        lines.append("  特徴量重要度 (上位10):")
        imp_sorted = result["importances"].nlargest(10)
        for feat, imp_val in imp_sorted.items():
            bar = "█" * int(imp_val * 40)
            lines.append(f"    {feat:<25} {imp_val:.4f}  {bar}")
            if feat in FEATURE_EXPLANATION:
                lines.append(f"      └ {FEATURE_EXPLANATION[feat]}")

        lines.append("")
        lines.append("  決定木ルール（全データ学習）:")
        lines.append("  (ルールのリーフノードが最終予測クラス)")
        for rule_line in result["rules_text"].splitlines():
            lines.append("    " + rule_line)

        lines.append("")
        if not errors:
            lines.append("  ✅ 予測失敗ケースなし（全サンプル正解）")
        else:
            lines.append(f"  ❌ 予測失敗ケース: {len(errors)} 件")
            lines.append("")
            for i, e in enumerate(errors, 1):
                lines.append(
                    f"  [{i}] trace={e['trace']}, K={e['k']}, "
                    f"sc={e['sc']}, update_type={e['update_type']}"
                )
                lines.append(
                    f"      正解={e['true']}  予測={e['predicted']}  "
                    f"MR={e['mean_MR']:.4f}  BMR={e['mean_BMR']:.4f}"
                )
                if e["causes"]:
                    lines.append("      原因（なぜこの条件が誤分類されたか）:")
                    for c in e["causes"]:
                        lines.append(f"       {c['explanation']}")
                        lines.append(
                            f"        → この特徴量の値が正解クラス({e['true']})より"
                            f"予測クラス({e['predicted']})の典型値に近かったため、"
                            f"モデルが誤った方向に判断した。"
                        )
                else:
                    lines.append(
                        "      原因: 重要特徴量では区別できず。"
                        "分布の複合的な要因（交互作用効果）が可能性として考えられる。"
                    )
                lines.append("")

    lines.append("")
    lines.append(sep)
    lines.append("  予測精度が低い場合の一般的な原因")
    lines.append(sep)
    lines.append(textwrap.dedent("""
  1. 学習サンプル数不足
     ・ K=8通り × sc=2 × update_type=4 = 64条件あっても、
       同一グループ内での比較なので実効サンプルは少ない。
     ・ 対策: 複数トレースを統合し、トレース間でモデルを汎化する。

  2. 最適Kのトレース依存性が高い
     ・ 同じ分布形状でも、キャッシュ充填パターンによって
       最適Kが変わることがある（サイズ分布のみでは予測不十分）。
     ・ 対策: ウォームアップ後の安定期のみで評価する特徴量を追加。

  3. sc の効果がKに依存する（交互作用）
     ・ sc=1（バイト重み付き）の効果は、大ファイルが多い場合に顕現する。
     ・ byte_concentration / byte_gini が 0.8 以上の場合に sc=1 が有効、
       それ以下では sc=0 と差がない傾向がある。
     ・ 対策: sc の予測に byte_concentration を閾値として使う決定ルールを優先。

  4. update_typeによる交絡
     ・ type-1（静的）は初期分布依存なので、特徴量が異なる意味を持つ。
     ・ 対策: update_typeごとにモデルを分離して学習する。

  5. ドリフトの非定常性
     ・ drift_trend が大きいトレースでは、平均特徴量が代表性を失う。
     ・ 対策: 後半の時間窓のみから特徴量を計算する別モードを追加する。
    """))
    lines.append(sep)

    out_path = os.path.join(out_dir, f"{label}_decision_rules.txt")
    with open(out_path, "w", encoding="utf-8") as f:
        f.write("\n".join(lines))
    print(f"  Saved: {out_path}")


