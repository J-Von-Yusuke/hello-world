def plot_prediction_result(feat_df: pd.DataFrame,
                           y_true: np.ndarray,
                           result: dict,
                           target_name: str,
                           out_dir: str,
                           label: str):
    """
    (a) 特徴量重要度  (b) 混同行列  (c) 相関ヒートマップ  を描画する
    """
    y_pred   = result["y_pred"]
    imp      = result["importances"]
    classes  = result["classes"]
    accuracy = result["accuracy"]

    fig = plt.figure(figsize=(18, 6))
    gs  = fig.add_gridspec(1, 3, wspace=0.35)

    # ── (a) 特徴量重要度 ──────────────────────────────────────────────────
    ax = fig.add_subplot(gs[0])
    top_n  = min(12, len(imp))
    top_imp = imp.nlargest(top_n)
    colors  = ["#1976D2" if v >= 0.1 else "#90CAF9" for v in top_imp.values]
    ax.barh(range(top_n), top_imp.values[::-1], color=colors[::-1],
            edgecolor="white", alpha=0.88)
    ax.set_yticks(range(top_n))
    ax.set_yticklabels(top_imp.index[::-1], fontsize=8)
    ax.set_xlabel("Feature importance", fontsize=9)
    ax.set_title(f"(a) Feature importance\n(target: {target_name})", fontsize=10)
    ax.axvline(0.1, color="red", linestyle="--", linewidth=0.8, alpha=0.6,
               label="threshold 0.10")
    ax.legend(fontsize=7)
    ax.grid(True, alpha=0.3, axis="x")

    # ── (b) 混同行列 ──────────────────────────────────────────────────────
    ax = fig.add_subplot(gs[1])
    le   = result["le"]
    y_te = le.transform(y_true)
    y_pe = le.transform(y_pred)
    cm   = confusion_matrix(y_te, y_pe)
    disp = ConfusionMatrixDisplay(
        confusion_matrix=cm,
        display_labels=[str(c) for c in classes],
    )
    disp.plot(ax=ax, colorbar=False, cmap="Blues")
    ax.set_title(
        f"(b) Confusion matrix  (LOO CV)\n"
        f"Accuracy = {accuracy:.1%}  |  n={len(y_true)}",
        fontsize=10,
    )
    ax.set_xlabel(f"Predicted {target_name}", fontsize=9)
    ax.set_ylabel(f"True {target_name}", fontsize=9)
    ax.tick_params(labelsize=8)

    # ── (c) 上位特徴量 vs ターゲットの Spearman 相関 ─────────────────────
    ax = fig.add_subplot(gs[2])
    feat_cols = [c for c in FEATURE_NAMES if c in feat_df.columns]
    y_num     = y_true.astype(float)
    corr_vals = []
    for fc in feat_cols:
        vals = feat_df[fc].values.astype(float)
        valid = ~(np.isnan(vals) | np.isnan(y_num))
        if valid.sum() < 3:
            corr_vals.append(0.0)
            continue
        r, _ = spearmanr(vals[valid], y_num[valid])
        corr_vals.append(float(r) if not np.isnan(r) else 0.0)

    corr_series = pd.Series(corr_vals, index=feat_cols).sort_values()
    bar_colors  = ["#F57C00" if v > 0 else "#1976D2" for v in corr_series.values]
    ax.barh(range(len(corr_series)), corr_series.values,
            color=bar_colors, edgecolor="white", alpha=0.85)
    ax.set_yticks(range(len(corr_series)))
    ax.set_yticklabels(corr_series.index, fontsize=7)
    ax.axvline(0, color="black", linewidth=0.8)
    ax.set_xlabel("Spearman correlation with target", fontsize=9)
    ax.set_title(
        f"(c) Feature-target Spearman correlation\n"
        f"orange=positive(larger feature → larger {target_name})",
        fontsize=10,
    )
    ax.grid(True, alpha=0.3, axis="x")

    plt.suptitle(
        f"Prediction of {target_name}  |  Label: {label}",
        fontsize=12, fontweight="bold"
    )
    fname = f"{label}_pred_{target_name.replace(' ', '_')}.png"
    fpath = os.path.join(out_dir, fname)
    plt.savefig(fpath, dpi=150, bbox_inches="tight")
    plt.close()
    print(f"  Saved: {fpath}")


def plot_error_analysis(feat_df: pd.DataFrame,
                        errors_k: list,
                        errors_sc: list,
                        importances_k: pd.Series,
                        importances_sc: pd.Series,
                        out_dir: str,
                        label: str):
    """
    予測失敗ケースを詳細に可視化する。
    (a) K予測失敗ケースの特徴量プロファイル（レーダー風バー）
    (b) sc予測失敗ケースの特徴量プロファイル
    """
    fig, axes = plt.subplots(1, 2, figsize=(16, 6))

    for ax, errors, importances, target_name in [
        (axes[0], errors_k,  importances_k,  "optimal_K"),
        (axes[1], errors_sc, importances_sc, "optimal_sc"),
    ]:
        top5 = importances.nlargest(5).index.tolist()

        if not errors:
            ax.text(0.5, 0.5, "No prediction errors!",
                    ha="center", va="center", fontsize=14,
                    color="green", transform=ax.transAxes)
            ax.set_title(f"Error analysis: {target_name}\n(All correct)", fontsize=11)
            ax.axis("off")
            continue

        # 失敗ケースと成功ケースで上位特徴量の平均を比較
        error_indices   = [e["index"] for e in errors]
        correct_indices = [i for i in range(len(feat_df)) if i not in error_indices]

        n_feats = len(top5)
        x = np.arange(n_feats)
        w = 0.35

        means_correct = []
        means_error   = []
        stds_correct  = []
        stds_error    = []

        for feat in top5:
            if feat not in feat_df.columns:
                means_correct.append(0); stds_correct.append(0)
                means_error.append(0);   stds_error.append(0)
                continue
            vals_c = feat_df.iloc[correct_indices][feat].values.astype(float)
            vals_e = feat_df.iloc[error_indices ][feat].values.astype(float)
            means_correct.append(np.nanmean(vals_c))
            stds_correct.append(np.nanstd(vals_c))
            means_error.append(np.nanmean(vals_e))
            stds_error.append(np.nanstd(vals_e))

        ax.bar(x - w/2, means_correct, w, yerr=stds_correct,
               label=f"Correct ({len(correct_indices)})",
               color="#388E3C", alpha=0.80, edgecolor="white",
               capsize=3, error_kw=dict(elinewidth=1))
        ax.bar(x + w/2, means_error, w, yerr=stds_error,
               label=f"Error ({len(errors)})",
               color="#F44336", alpha=0.80, edgecolor="white",
               capsize=3, error_kw=dict(elinewidth=1))

        ax.set_xticks(x)
        ax.set_xticklabels(top5, rotation=20, ha="right", fontsize=8)
        ax.set_title(
            f"Error analysis: {target_name}\n"
            f"Top-5 important features  (mean ± std)",
            fontsize=10,
        )
        ax.set_ylabel("Feature value (normalized per feature)", fontsize=9)
        ax.legend(fontsize=8)
        ax.grid(True, alpha=0.3, axis="y")

        # エラーケースの詳細注釈
        if len(errors) <= 6:
            note_lines = [f"Misclassified cases ({len(errors)}):"]
            for e in errors:
                note_lines.append(
                    f"  trace={e['trace']}, K={e['k']}, sc={e['sc']}, "
                    f"type={e['update_type']}  "
                    f"true={e['true']} pred={e['predicted']}"
                )
            note = "\n".join(note_lines)
            ax.text(0.01, 0.99, note,
                    transform=ax.transAxes,
                    fontsize=6.5, va="top", ha="left",
                    bbox=dict(boxstyle="round,pad=0.3",
                              fc="lightyellow", alpha=0.8, ec="#cccc88"))

    plt.suptitle(f"Prediction Error Analysis  |  Label: {label}", fontsize=12)
    plt.tight_layout()
    fpath = os.path.join(out_dir, f"{label}_error_analysis.png")
    plt.savefig(fpath, dpi=150, bbox_inches="tight")
    plt.close()
    print(f"  Saved: {fpath}")


