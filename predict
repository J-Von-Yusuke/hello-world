# 実験トレース向けオンライン予測
# ══════════════════════════════════════════════════════════════════════════════

def recommend_update_strategy() -> str:
    """
    「並列シャドウ実行 + 遅延コミット」(Parallel Shadow + Deferred Commit) 戦略の説明文を返す。

    設計根拠:
    - WMAは履歴が必要なため「途中から有効化」が難しいが、
      全 update_type を最初から並列に shadow 実行しておけばコストは軽い。
    - 観測フェーズ終了時点で js_effective が最も小さい type をコミットする。
    - 一度コミットした後は原則変更しない（ヒステリシス付き再評価で例外対応）。
    """
    return textwrap.dedent(f"""
    ═══════════════════════════════════════════════════════════════
     更新戦略: 並列シャドウ実行 + 遅延コミット
     (Parallel Shadow Execution + Deferred Commit)
    ═══════════════════════════════════════════════════════════════

    Phase 1  [観測フェーズ: 最初の {SHADOW_OBSERVATION_WINDOWS} 窓]
    ────────────────────────────────────────────────────────────────
    - 4 種類の update_type (-1, 0, 1, 2) を並列にシャドウ実行する。
      実際の閾値更新は行わず、各 type が適用された場合の
      js_effective (=JS(view_counts_make, view_counts_now)) を記録。
    - WMAは観測フェーズ中から履歴を蓄積するので、コミット後すぐ利用可能。
    - ML予測モデル（本スクリプト）が推奨する K と sc もこの期間に確定する。

    Phase 2  [決定フェーズ: 窓 {SHADOW_OBSERVATION_WINDOWS} 時点]
    ────────────────────────────────────────────────────────────────
    - 4 type のうち mean(js_effective) が最小だった type をコミット。
    - K と sc は ML予測値を採用（教師トレースで学習済みモデルを使用）。
    - 推奨値と ML予測値が一致した type を最優先でコミット。

    Phase 3  [運用フェーズ: 窓 {SHADOW_OBSERVATION_WINDOWS}+ 以降]
    ────────────────────────────────────────────────────────────────
    - 一度コミットした設定は原則維持する。
    - ドリフト監視: 各窓で js_inherent を計算し、
        |js_inherent_current - js_inherent_initial| > {DRIFT_REEVAL_THRESHOLD}
      が M 窓連続した場合のみ再評価をトリガー（M はハイパーパラメータ）。
    - 再評価時は Phase 1 に戻り、再び {SHADOW_OBSERVATION_WINDOWS} 窓の
      シャドウ観測を行ってからコミットし直す（二重コミット防止）。

    利点
    ────────────────────────────────────────────────────────────────
    - WMA の履歴問題を「観測フェーズ中の事前暖気」で解決。
    - 逐次更新より安定（ヒステリシスにより短期ノイズを無視できる）。
    - 「決めたら変えない」方針でキャッシュの安定性を確保しつつ、
      長期ドリフトへの適応も可能。

    """).strip()




def predict_for_experiment_traces(
        experiment_filepaths: list[str],
        result_k:   dict,
        result_sc:  dict,
        result_ut:  dict,
        feature_names_used: list[str],
        out_dir: str,
        label: str,
) -> "pd.DataFrame":
    """
    Experiment trace CSV files -> extract features -> predict K/sc/update_type.

    Parameters
    ----------
    experiment_filepaths : list[str]
    result_k, result_sc, result_ut : dict  (from train_and_evaluate)
    feature_names_used : list[str]
    out_dir, label : str

    Returns
    -------
    pd.DataFrame  with pred_K, pred_sc, pred_update_type per file
    """
    rows = []
    for fp in experiment_filepaths:
        info = parse_filename(fp)
        if info is None:
            print(f"  [skip] Not SIZEDIVIDE format: {fp}")
            continue

        feat = extract_features(fp)
        if feat is None:
            print(f"  [skip] Feature extraction failed: {fp}")
            continue

        x_vec = np.array([feat.get(fn, np.nan) for fn in feature_names_used],
                         dtype=float).reshape(1, -1)
        nan_mask = np.isnan(x_vec)
        if nan_mask.any():
            x_vec[nan_mask] = 0.0

        pred_k = info["k"];            conf_k = np.nan
        pred_sc = info["size_correction"]; conf_sc = np.nan
        pred_ut = info["update_type"]; conf_ut = np.nan

        if result_k.get("model") is not None:
            proba = result_k["model"].predict_proba(x_vec)[0]
            idx   = int(np.argmax(proba))
            pred_k = int(result_k["le"].inverse_transform([idx])[0])
            conf_k = float(proba[idx])

        if result_sc.get("model") is not None:
            proba = result_sc["model"].predict_proba(x_vec)[0]
            idx   = int(np.argmax(proba))
            pred_sc = int(result_sc["le"].inverse_transform([idx])[0])
            conf_sc = float(proba[idx])

        if result_ut.get("model") is not None:
            proba = result_ut["model"].predict_proba(x_vec)[0]
            idx   = int(np.argmax(proba))
            pred_ut = int(result_ut["le"].inverse_transform([idx])[0])
            conf_ut = float(proba[idx])

        rows.append({
            "trace":            info["trace"],
            "filepath":         fp,
            "file_k":           info["k"],
            "file_sc":          info["size_correction"],
            "file_update_type": info["update_type"],
            "pred_K":           pred_k,
            "conf_K":           conf_k,
            "pred_sc":          pred_sc,
            "conf_sc":          conf_sc,
            "pred_update_type": pred_ut,
            "conf_update_type": conf_ut,
            **{fn: feat.get(fn, np.nan) for fn in feature_names_used},
        })

    if not rows:
        print("  [warning] No valid experiment traces.")
        return pd.DataFrame()

    pred_df = pd.DataFrame(rows)

    # ---- text report ---------------------------------------------------
    lines_out = []
    sep = "=" * 72
    lines_out.append(sep)
    lines_out.append(f"  実験トレース オンライン予測レポート  |  Label: {label}")
    lines_out.append(sep)
    lines_out.append("")
    lines_out.append(recommend_update_strategy())
    lines_out.append("")
    lines_out.append("── ML予測結果（実験トレース別） " + "─" * 38)
    lines_out.append("")

    for trace_name, grp in pred_df.groupby("trace"):
        def _mode(s):
            vc = s.value_counts()
            return vc.index[0] if len(vc) > 0 else None

        rec_k  = _mode(grp["pred_K"])
        rec_sc = _mode(grp["pred_sc"])
        rec_ut = _mode(grp["pred_update_type"])
        ut_label = UPDATE_TYPE_LABEL_EN.get(rec_ut, str(rec_ut))

        lines_out.append(f"  Trace: {trace_name}")
        lines_out.append(f"    推奨 K           : {rec_k}  (avg conf={grp['conf_K'].mean():.2f})")
        lines_out.append(f"    推奨 sc          : {rec_sc}  (avg conf={grp['conf_sc'].mean():.2f})")
        lines_out.append(f"    推奨 update_type : {rec_ut} ({ut_label})")
        lines_out.append(f"                       avg conf={grp['conf_update_type'].mean():.2f}")
        lines_out.append(f"    対象ファイル数   : {len(grp)}")
        lines_out.append("")
        lines_out.append("    Parallel Shadow + Deferred Commit 運用手順:")
        lines_out.append(f"      1. 最初の {SHADOW_OBSERVATION_WINDOWS} 窓で全 update_type を並列シャドウ実行")
        lines_out.append(f"      2. js_effective が最小の type を採用（ML推奨: {rec_ut}）")
        lines_out.append(f"      3. K={rec_k}, sc={rec_sc} を適用して通常運用を開始")
        lines_out.append(f"      4. js_inherent 変動が >{DRIFT_REEVAL_THRESHOLD:.2f} で M 窓連続したら再評価")
        lines_out.append("")

    lines_out.append(sep)

    report_path = os.path.join(out_dir, f"{label}_experiment_predictions.txt")
    with open(report_path, "w", encoding="utf-8") as fh:
        fh.write("\n".join(lines_out))
    print(f"  Saved: {report_path}")

    csv_path = os.path.join(out_dir, f"{label}_experiment_predictions.csv")
    pred_df.to_csv(csv_path, index=False, encoding="utf-8-sig")
    print(f"  Saved: {csv_path}")

    return pred_df


# ══════════════════════════════════════════════════════════════════════════════
# メイン処理
# ══════════════════════════════════════════════════════════════════════════════

def run_prediction(meta: pd.DataFrame,
                   label: str,
                   out_dir: str,
                   target: str = "combined",
                   w_mr: float = 0.5,
                   w_bmr: float = 0.5,
                   max_depth: int = 4) -> dict:
    """
    教師データ (meta) を使って K・sc・update_type の予測モデルを学習・評価する。

    Returns
    -------
    dict: result_k, result_sc, result_ut, feature_names_used, feat_df
          (失敗時は空 dict)
    """
    print(f"\n  [1/6] 性能データを読み込んで最適条件を決定中...")
    perf_df = determine_targets(meta, target=target, w_mr=w_mr, w_bmr=w_bmr)
    if perf_df.empty:
        print("  [スキップ] 有効データなし")
        return {}

    print(f"  [2/6] 特徴量を抽出中 ({len(perf_df)} 条件)...")
    feat_df = build_feature_matrix(perf_df)
    if feat_df.empty:
        print("  [スキップ] 特徴量抽出失敗")
        return {}

    feat_path = os.path.join(out_dir, f"{label}_features.csv")
    feat_df.to_csv(feat_path, index=False, encoding="utf-8-sig")
    print(f"  Saved: {feat_path}")

    X = feat_df[[f for f in FEATURE_NAMES if f in feat_df.columns]].values.astype(float)
    feature_names_used = [f for f in FEATURE_NAMES if f in feat_df.columns]

    col_means = np.nanmean(X, axis=0)
    inds = np.where(np.isnan(X))
    X[inds] = np.take(col_means, inds[1])

    print(f"\n  [3/6] optimal_K を予測 (target={target})...")
    y_k      = feat_df["optimal_K"].values.astype(int)
    result_k = train_and_evaluate(X, y_k, feature_names_used, "optimal_K", max_depth)
    print(f"         LOO accuracy = {result_k['accuracy']:.1%}")
    print(result_k["report"])

    print(f"  [3/6] optimal_sc を予測 (target={target})...")
    y_sc      = feat_df["optimal_sc"].values.astype(int)
    result_sc = train_and_evaluate(X, y_sc, feature_names_used, "optimal_sc", max_depth)
    print(f"         LOO accuracy = {result_sc['accuracy']:.1%}")
    print(result_sc["report"])

    print(f"  [3/6] optimal_update_type を予測 (target={target})...")
    y_ut      = feat_df["optimal_update_type"].values.astype(int)
    result_ut = train_and_evaluate(X, y_ut, feature_names_used, "optimal_update_type", max_depth)
    print(f"         LOO accuracy = {result_ut['accuracy']:.1%}")
    print(result_ut["report"])

    print(f"\n  [4/6] 誤差分析中...")
    errors_k  = analyze_errors(feat_df, y_k,  result_k["y_pred"],
                               feature_names_used, result_k["importances"],  "optimal_K")
    errors_sc = analyze_errors(feat_df, y_sc, result_sc["y_pred"],
                               feature_names_used, result_sc["importances"], "optimal_sc")
    errors_ut = analyze_errors(feat_df, y_ut, result_ut["y_pred"],
                               feature_names_used, result_ut["importances"], "optimal_update_type")
    print(f"         K           予測失敗: {len(errors_k)}  / {len(y_k)} 件")
    print(f"         sc          予測失敗: {len(errors_sc)} / {len(y_sc)} 件")
    print(f"         update_type 予測失敗: {len(errors_ut)} / {len(y_ut)} 件")

    print(f"\n  [5/6] グラフとレポートを出力中...")
    plot_prediction_result(feat_df, y_k,  result_k,  "optimal_K",           out_dir, label)
    plot_prediction_result(feat_df, y_sc, result_sc, "optimal_sc",           out_dir, label)
    plot_prediction_result(feat_df, y_ut, result_ut, "optimal_update_type",  out_dir, label)
    plot_error_analysis(feat_df, errors_k, errors_sc,
                        result_k["importances"], result_sc["importances"],
                        out_dir, label)
    write_text_report(result_k, result_sc, errors_k, errors_sc,
                      feat_df, out_dir, label, target)

    print(f"\n  [6/6] update_type 予測ルールをテキスト出力...")
    ut_report_path = os.path.join(out_dir, f"{label}_update_type_rules.txt")
    with open(ut_report_path, "w", encoding="utf-8") as fh:
        fh.write(f"optimal_update_type 予測ルール  |  LOO accuracy={result_ut['accuracy']:.1%}\n")
        fh.write("=" * 60 + "\n")
        fh.write(result_ut["rules_text"])
        fh.write("\n\n" + recommend_update_strategy())
    print(f"  Saved: {ut_report_path}")

    print(f"\n  ── サマリー ({label}) ──")
    print(f"     optimal_K           LOO accuracy: {result_k['accuracy']:.1%}")
    print(f"     optimal_sc          LOO accuracy: {result_sc['accuracy']:.1%}")
    print(f"     optimal_update_type LOO accuracy: {result_ut['accuracy']:.1%}")
    print(f"     K           予測失敗: {len(errors_k)} 件")
    print(f"     sc          予測失敗: {len(errors_sc)} 件")
    print(f"     update_type 予測失敗: {len(errors_ut)} 件")
    top_k_feat  = result_k["importances"].idxmax()
    top_sc_feat = result_sc["importances"].idxmax()
    top_ut_feat = result_ut["importances"].idxmax()
    print(f"     K           予測の最重要特徴量: {top_k_feat}")
    print(f"     sc          予測の最重要特徴量: {top_sc_feat}")
    print(f"     update_type 予測の最重要特徴量: {top_ut_feat}")

    return {
        "result_k":           result_k,
        "result_sc":          result_sc,
        "result_ut":          result_ut,
        "feature_names_used": feature_names_used,
        "feat_df":            feat_df,
    }


def main():
    parser = argparse.ArgumentParser(
        description="最適K・sc・update_type 予測（教師/実験トレース分割対応）",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent("""
        使用例:
          # 全トレースで学習（TEACHER_TRACES/EXPERIMENT_TRACES をコード内にハードコーディング）
          python predict_optimal_params.py --dir ./results --out ./output

          # CLI で教師/実験トレースを明示指定
          python predict_optimal_params.py --dir ./results --out ./output \\
              --teacher wiki2019 twitter --experiment cachelib_cdn01

          # MR重視の combined score で学習
          python predict_optimal_params.py --dir ./results --target combined --w-mr 0.7 --w-bmr 0.3

          # トレースごとに個別に予測
          python predict_optimal_params.py --dir ./results --split-traces
        """),
    )
    parser.add_argument("--dir",       required=True, help="CSVディレクトリ")
    parser.add_argument("--out",       default="./output", help="出力ディレクトリ")
    parser.add_argument("--target",    default="combined",
                        choices=["mr", "bmr", "combined"],
                        help="最適化ターゲット (default: combined)")
    parser.add_argument("--w-mr",      type=float, default=0.5)
    parser.add_argument("--w-bmr",     type=float, default=0.5)
    parser.add_argument("--trace",     default=None,
                        help="特定トレースのみ処理（教師側のみに適用）")
    parser.add_argument("--split-traces", action="store_true",
                        help="トレースごとに個別に予測（教師フェーズ）")
    parser.add_argument("--label",     default=None,
                        help="出力ファイル名プレフィックス（省略時: ディレクトリ名）")
    parser.add_argument("--max-depth", type=int, default=4,
                        help="決定木の最大深さ (default 4)")
    parser.add_argument("--teacher",   nargs="*", default=None, metavar="TRACE",
                        help="教師トレース名（複数可）。指定するとコード内 TEACHER_TRACES を上書き")
    parser.add_argument("--experiment", nargs="*", default=None, metavar="TRACE",
                        help="実験トレース名（複数可）。指定するとコード内 EXPERIMENT_TRACES を上書き")
    args = parser.parse_args()

    os.makedirs(args.out, exist_ok=True)

    total_w = args.w_mr + args.w_bmr
    w_mr  = args.w_mr  / total_w
    w_bmr = args.w_bmr / total_w

    print("[1/3] CSVをスキャン中...")
    meta = collect_csvs(args.dir)
    all_traces = sorted(meta["trace"].unique())
    print(f"  {len(meta)} 件, トレース={all_traces}")

    teacher_list    = args.teacher    if args.teacher    is not None else TEACHER_TRACES
    experiment_list = args.experiment if args.experiment is not None else EXPERIMENT_TRACES

    has_split = bool(teacher_list) or bool(experiment_list)

    if has_split:
        if not teacher_list:
            teacher_list = [t for t in all_traces if t not in experiment_list]
        if not experiment_list:
            experiment_list = [t for t in all_traces if t not in teacher_list]

        overlap = set(teacher_list) & set(experiment_list)
        if overlap:
            print(f"  [警告] 教師と実験に重複トレースがあります: {overlap}")

        print(f"\n[2/3] 教師フェーズ: {teacher_list}")
        meta_teacher = meta[meta["trace"].isin(teacher_list)].copy()
        if meta_teacher.empty:
            raise ValueError(f"教師トレースが見つかりません: {teacher_list}")

        label_teacher = args.label or f"{Path(args.dir).name}_teacher"
        trained = run_prediction(
            meta_teacher, label_teacher, args.out,
            target=args.target, w_mr=w_mr, w_bmr=w_bmr,
            max_depth=args.max_depth,
        )

        if not trained:
            print("  [エラー] 教師フェーズで学習に失敗しました。")
            return

        print(f"\n[3/3] 実験フェーズ: {experiment_list}")
        meta_exp = meta[meta["trace"].isin(experiment_list)].copy()
        if meta_exp.empty:
            print(f"  [警告] 実験トレースが見つかりません: {experiment_list}")
        else:
            label_exp = args.label or f"{Path(args.dir).name}_experiment"
            predict_for_experiment_traces(
                experiment_filepaths = meta_exp["filepath"].tolist(),
                result_k             = trained["result_k"],
                result_sc            = trained["result_sc"],
                result_ut            = trained["result_ut"],
                feature_names_used   = trained["feature_names_used"],
                out_dir              = args.out,
                label                = label_exp,
            )
    else:
        print(f"\n[2/3] 通常モードで学習中（教師/実験分割なし）...")
        if args.split_traces:
            target_traces = all_traces
            if args.trace:
                target_traces = [args.trace]
            for trace in target_traces:
                meta_t = meta[meta["trace"] == trace].copy()
                run_prediction(meta_t, trace, args.out,
                               target=args.target, w_mr=w_mr, w_bmr=w_bmr,
                               max_depth=args.max_depth)
        else:
            if args.trace:
                meta = meta[meta["trace"] == args.trace].copy()
            label = args.label or Path(args.dir).name
            run_prediction(meta, label, args.out,
                           target=args.target, w_mr=w_mr, w_bmr=w_bmr,
                           max_depth=args.max_depth)

    print(f"\nAll done. Output: {args.out}/")


if __name__ == "__main__":
    main()
