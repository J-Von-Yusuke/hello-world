def build_feature_matrix(perf_df: pd.DataFrame) -> pd.DataFrame:
    """
    perf_df の各行（=1つのCSV条件）に特徴量を付与して返す。
    """
    feat_rows = []
    for _, row in perf_df.iterrows():
        feat = extract_features(row["filepath"])
        if feat is None:
            continue
        feat_rows.append({**row.to_dict(), **feat})
    return pd.DataFrame(feat_rows)


def train_and_evaluate(X: np.ndarray, y: np.ndarray,
                       feature_names: list,
                       target_name: str,
                       max_depth: int = 4) -> dict:
    """
    決定木を LeaveOneOut 交差検証で評価する。
    少数サンプルでも過学習の影響を確認できる。

    Returns:
        dict with keys: model, y_pred, accuracy, report, importances, rules_text
    """
    le = LabelEncoder()
    y_enc = le.fit_transform(y)

    clf = DecisionTreeClassifier(
        max_depth=max_depth,
        min_samples_leaf=2,
        random_state=42,
    )

    if len(np.unique(y_enc)) < 2:
        # クラスが1種類しかない場合は予測不要
        return {
            "model": None,
            "y_pred": y,
            "accuracy": 1.0,
            "report": "(Only one class present — prediction trivial)",
            "importances": pd.Series(
                np.zeros(len(feature_names)), index=feature_names
            ),
            "rules_text": "(Only one class)",
            "le": le,
            "classes": le.classes_,
        }

    # Leave-One-Out cross-validation
    if len(X) <= 10:
        cv = LeaveOneOut()
    else:
        from sklearn.model_selection import StratifiedKFold
        cv = StratifiedKFold(n_splits=min(5, len(X)), shuffle=True, random_state=42)

    y_pred_enc = cross_val_predict(clf, X, y_enc, cv=cv)
    y_pred     = le.inverse_transform(y_pred_enc)
    acc        = accuracy_score(y_enc, y_pred_enc)
    report     = classification_report(
        y_enc, y_pred_enc,
        target_names=[str(c) for c in le.classes_],
        zero_division=0,
    )

    # 全データで再学習してルールを抽出（解釈用）
    clf.fit(X, y_enc)
    importances = pd.Series(clf.feature_importances_, index=feature_names)
    rules_text  = export_text(clf, feature_names=feature_names, max_depth=max_depth)

    return {
        "model": clf,
        "y_pred": y_pred,
        "accuracy": acc,
        "report": report,
        "importances": importances,
        "rules_text": rules_text,
        "le": le,
        "classes": le.classes_,
    }


# ══════════════════════════════════════════════════════════════════════════════
# 誤差分析
# ══════════════════════════════════════════════════════════════════════════════

def analyze_errors(feat_df: pd.DataFrame,
                   y_true: np.ndarray,
                   y_pred: np.ndarray,
                   feature_names: list,
                   importances: pd.Series,
                   target_name: str) -> list[dict]:
    """
    予測が外れた行を特定し、どの特徴量が誤判断の原因かを説明する。

    Returns: list of dicts, one per misclassified sample
    """
    errors = []
    top_feats = importances.nlargest(5).index.tolist()

    for i, (true_val, pred_val) in enumerate(zip(y_true, y_pred)):
        if true_val == pred_val:
            continue

        row = feat_df.iloc[i]

        # 正解ラベルの条件と予測ラベルの条件の特徴量を比較
        # 「どの特徴量が予測ラベルの典型値に近くて混乱させたか」を調べる
        causes = []
        for feat in top_feats:
            if feat not in feat_df.columns:
                continue
            feat_val = row[feat]
            # 正解ラベルグループの平均
            mask_true = (np.array(y_true) == true_val)
            mask_pred = (np.array(y_true) == pred_val)
            mean_true = feat_df.loc[mask_true, feat].mean() if mask_true.sum() > 0 else np.nan
            mean_pred = feat_df.loc[mask_pred, feat].mean() if mask_pred.sum() > 0 else np.nan

            if np.isnan(mean_true) or np.isnan(mean_pred):
                continue

            # この特徴量が予測クラス側に近い場合 → 原因の一つ
            dist_to_true = abs(feat_val - mean_true)
            dist_to_pred = abs(feat_val - mean_pred)
            if dist_to_pred < dist_to_true:
                direction = ("higher" if feat_val > mean_true else "lower")
                causes.append({
                    "feature":    feat,
                    "value":      float(feat_val),
                    "mean_true":  float(mean_true),
                    "mean_pred":  float(mean_pred),
                    "direction":  direction,
                    "explanation": (
                        f"  '{feat}' = {feat_val:.4f}  "
                        f"(true-class avg={mean_true:.4f}, "
                        f"predicted-class avg={mean_pred:.4f})  "
                        f"→ value is closer to predicted class"
                    ),
                })

        errors.append({
            "index":      i,
            "true":       true_val,
            "predicted":  pred_val,
            "trace":      row.get("trace", "?"),
            "k":          row.get("k", "?"),
            "sc":         row.get("size_correction", "?"),
            "update_type": row.get("update_type", "?"),
            "mean_MR":    row.get("mean_MR", np.nan),
            "mean_BMR":   row.get("mean_BMR", np.nan),
            "causes":     causes,
        })
    return errors


