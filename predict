def gini_coeff(prob: np.ndarray) -> float:
    """Gini 係数（0=均等, 1=完全集中）"""
    p = np.sort(prob.astype(float))
    n = len(p)
    if n == 0 or p.sum() == 0:
        return 0.0
    cumsum = np.cumsum(p)
    return float(1 - 2 * cumsum.sum() / (n * p.sum()) + 1 / n)


def count_peaks(prob: np.ndarray, threshold: float = 0.02) -> int:
    """prob 内のローカル最大点（値が threshold 以上）の数を返す"""
    peaks = 0
    for i in range(1, len(prob) - 1):
        if prob[i] > prob[i-1] and prob[i] > prob[i+1] and prob[i] >= threshold:
            peaks += 1
    return max(peaks, 1)


def extract_features(filepath: str) -> dict | None:
    """
    1つのCSVから予測に使う特徴量を抽出する。
    これらの特徴量はオンラインで観測可能な分布統計量のみで構成される。

    Returns dict with keys:
        entropy, norm_entropy, top1_concentration, top3_concentration,
        gini_request, n_peaks, peak_bin,
        mean_drift, std_drift, max_drift, drift_trend,
        byte_concentration, byte_gini, byte_mean_size,
        cv_dist (coefficient of variation across windows)
    """
    try:
        df = pd.read_csv(filepath)
        df.columns = df.columns.str.strip().str.lower()
    except Exception as e:
        print(f"  [読込エラー] {filepath}: {e}")
        return None

    now_cols  = find_series_cols(df, "view_counts_now")
    make_cols = find_series_cols(df, "view_counts_make")

    if not now_cols or not make_cols:
        return None

    now_arr  = df[now_cols].values.astype(float)   # shape: (T, B)
    make_arr = df[make_cols].values.astype(float)

    T, B = now_arr.shape
    bin_indices = np.arange(B)

    # ── 平均分布（全時間窓の平均） ────────────────────────────────────────
    mean_dist      = now_arr.mean(axis=0)
    mean_dist_prob = to_prob(mean_dist)

    # Shannon エントロピー
    ent = float(scipy_entropy(mean_dist_prob))
    norm_ent = ent / np.log(B) if B > 1 else 0.0

    # 集中度
    sorted_p    = np.sort(mean_dist_prob)[::-1]
    top1_conc   = float(sorted_p[0])
    top3_conc   = float(sorted_p[:3].sum())

    # Gini（リクエスト分布の不均一性）
    gini_req = gini_coeff(mean_dist_prob)

    # ピーク数・主ピーク位置
    n_pk   = count_peaks(mean_dist_prob)
    pk_bin = int(np.argmax(mean_dist_prob))

    # ── 時間ドリフト統計 ──────────────────────────────────────────────────
    js_vals = []
    for i in range(T):
        d_t    = to_prob(now_arr[i])
        d_prev = to_prob(make_arr[i])
        js_vals.append(js_div(d_prev, d_t))

    js_vals   = np.array(js_vals)
    mean_drift = float(js_vals.mean())
    std_drift  = float(js_vals.std())
    max_drift  = float(js_vals.max())

    # ドリフトの線形トレンド（正=時間とともにドリフト増加）
    if T > 2:
        drift_trend = float(np.polyfit(np.arange(T), js_vals, 1)[0])
    else:
        drift_trend = 0.0

    # ── バイト負荷特徴量（sc 予測のキー特徴量） ───────────────────────────
    # バケット i のコンテンツサイズ代表値を 2^i とする（ヒストグラムの設計上）
    byte_weights    = np.power(2.0, bin_indices.astype(float))
    byte_dist       = mean_dist_prob * byte_weights
    byte_total      = byte_dist.sum()
    byte_dist_norm  = byte_dist / (byte_total + EPSILON)

    # 大きいサイズ上位3バケットへのバイト集中度
    byte_top3_conc  = float(np.sort(byte_dist_norm)[::-1][:3].sum())
    byte_gini_val   = gini_coeff(byte_dist_norm)
    byte_mean_size  = float(np.dot(bin_indices, byte_dist_norm))  # 加重平均バケット番号

    # ── 分布の時間的ばらつき（各バケットのCV） ──────────────────────────
    # 各バケットのリクエスト数が時間によってどれだけ変動するか
    col_std  = now_arr.std(axis=0)
    col_mean = now_arr.mean(axis=0) + EPSILON
    cv_per_bin = col_std / col_mean
    cv_dist    = float(cv_per_bin.mean())  # 平均変動係数

    # ── 区間ミス率特徴量（CSVにinterval列がある場合のみ）────────────────────
    # これらはオンライン実運用でリアルタイムに観測できる特徴量
    mean_inter_mr     = np.nan
    std_inter_mr      = np.nan
    mean_delta_mr_lru = np.nan
    byte_vol_cv       = np.nan

    if "inter_miss_ratio" in df.columns:
        imr = pd.to_numeric(df["inter_miss_ratio"], errors="coerce").dropna()
        if len(imr) > 0:
            mean_inter_mr = float(imr.mean())
            std_inter_mr  = float(imr.std()) if len(imr) > 1 else 0.0

    if "inter_miss_ratio" in df.columns and "inter_miss_ratio_lru" in df.columns:
        imr     = pd.to_numeric(df["inter_miss_ratio"],     errors="coerce")
        imr_lru = pd.to_numeric(df["inter_miss_ratio_lru"], errors="coerce")
        delta   = (imr - imr_lru).dropna()
        if len(delta) > 0:
            mean_delta_mr_lru = float(delta.mean())

    if "req_byte" in df.columns:
        rb = pd.to_numeric(df["req_byte"], errors="coerce").dropna()
        if len(rb) > 1:
            byte_vol_cv = float(rb.std() / (rb.mean() + EPSILON))

    return {
        # 分布形状
        "entropy":           ent,
        "norm_entropy":      norm_ent,
        "top1_concentration": top1_conc,
        "top3_concentration": top3_conc,
        "gini_request":      gini_req,
        "n_peaks":           n_pk,
        "peak_bin":          pk_bin,
        # 時間ドリフト
        "mean_drift":        mean_drift,
        "std_drift":         std_drift,
        "max_drift":         max_drift,
        "drift_trend":       drift_trend,
        # バイト負荷（sc予測）
        "byte_concentration": byte_top3_conc,
        "byte_gini":          byte_gini_val,
        "byte_mean_size":     byte_mean_size,
        # 時間変動
        "cv_dist":            cv_dist,
        # 区間ミス率（リアルタイム観測特徴量 / NaN if not available）
        "mean_inter_mr":      mean_inter_mr,
        "std_inter_mr":       std_inter_mr,
        "mean_delta_mr_lru":  mean_delta_mr_lru,
        "byte_vol_cv":        byte_vol_cv,
    }


