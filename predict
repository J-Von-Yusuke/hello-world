def _plot_regret(pred_df, out_dir, label):
    """
    Regret comparison: ML model vs Lag-1 baseline vs Majority baseline.

    Output: {label}_experiment_regret.png
      Top row   : rolling-20 regret_mr over time per trace
      Bottom row: box plot of regret_mr per method per trace
    """
    if pred_df.empty:
        return

    has_regret = all(c in pred_df.columns for c in
                     ["regret_mr", "regret_mr_lag1", "regret_mr_maj"])
    if not has_regret:
        return
    has_regret_bmr = all(c in pred_df.columns for c in
                         ["regret_bmr", "regret_bmr_lag1", "regret_bmr_maj"])
    n_rows_regret = 4 if has_regret_bmr else 2

    traces = pred_df["trace"].unique()
    n_tr   = len(traces)

    fig, axes = plt.subplots(n_rows_regret, n_tr,
                             figsize=(max(7, 6 * n_tr), 4.5 * n_rows_regret),
                             squeeze=False)

    for col_i, trace_name in enumerate(traces):
        grp = pred_df[pred_df["trace"] == trace_name].sort_values("window")
        ws  = grp["window"].values

        # ── Rows 0/1: mr ──────────────────────────────────
        methods_mr = [
            ("regret_mr",      "#9C27B0", "ML model"),
            ("regret_mr_lag1", "#F57C00", "Lag-1"),
            ("regret_mr_maj",  "#9E9E9E", "Majority"),
        ]
        ax_r0 = axes[0, col_i]
        for col, color, lbl in methods_mr:
            if col not in grp.columns:
                continue
            vals = pd.to_numeric(grp[col], errors="coerce")
            roll = vals.rolling(20, min_periods=1).mean().values
            ax_r0.plot(ws, roll, color=color, linewidth=1.3, label=lbl)
        ax_r0.axhline(0.0, color="green", linestyle="--", linewidth=0.8, alpha=0.7)
        ax_r0.set_title(f"Trace: {trace_name}\nRolling-20 Regret MR", fontsize=9)
        ax_r0.set_xlabel("Window t")
        ax_r0.set_ylabel("Rolling-20 Regret MR (lower=better)")
        ax_r0.legend(fontsize=8)
        ax_r0.grid(True, alpha=0.3)

        ax_r1 = axes[1, col_i]
        box_data_mr   = []
        box_labels_mr = []
        box_colors_mr = []
        for col, color, lbl in methods_mr:
            if col not in grp.columns:
                continue
            vals = pd.to_numeric(grp[col], errors="coerce").dropna().values
            box_data_mr.append(vals)
            box_labels_mr.append(lbl)
            box_colors_mr.append(color)
        if box_data_mr:
            bp_mr = ax_r1.boxplot(box_data_mr, patch_artist=True,
                                medianprops=dict(color="black", linewidth=1.5),
                                flierprops=dict(marker=".", markersize=3, alpha=0.4))
            for patch, color in zip(bp_mr["boxes"], box_colors_mr):
                patch.set_facecolor(color)
                patch.set_alpha(0.65)
            ax_r1.set_xticklabels(box_labels_mr, fontsize=9)
        ax_r1.axhline(0.0, color="green", linestyle="--", linewidth=0.8, alpha=0.7)
        ax_r1.set_title(f"Trace: {trace_name}\nRegret MR distribution", fontsize=9)
        ax_r1.set_ylabel("Regret MR")
        ax_r1.grid(True, alpha=0.3, axis="y")
        for i, vals in enumerate(box_data_mr, start=1):
            med = float(np.nanmedian(vals))
            ax_r1.text(i, med, f" {med:.4f}", fontsize=7,
                       va="center", ha="left", color="black")

        if not has_regret_bmr:
            continue

        # ── Rows 2/3: bmr ──────────────────────────────────
        methods_bmr = [
            ("regret_bmr",      "#0288D1", "ML model"),
            ("regret_bmr_lag1", "#F57C00", "Lag-1"),
            ("regret_bmr_maj",  "#9E9E9E", "Majority"),
        ]
        ax_r0 = axes[2, col_i]
        for col, color, lbl in methods_bmr:
            if col not in grp.columns:
                continue
            vals = pd.to_numeric(grp[col], errors="coerce")
            roll = vals.rolling(20, min_periods=1).mean().values
            ax_r0.plot(ws, roll, color=color, linewidth=1.3, label=lbl)
        ax_r0.axhline(0.0, color="green", linestyle="--", linewidth=0.8, alpha=0.7)
        ax_r0.set_title(f"Trace: {trace_name}\nRolling-20 Regret BMR", fontsize=9)
        ax_r0.set_xlabel("Window t")
        ax_r0.set_ylabel("Rolling-20 Regret BMR (lower=better)")
        ax_r0.legend(fontsize=8)
        ax_r0.grid(True, alpha=0.3)

        ax_r1 = axes[3, col_i]
        box_data_bmr   = []
        box_labels_bmr = []
        box_colors_bmr = []
        for col, color, lbl in methods_bmr:
            if col not in grp.columns:
                continue
            vals = pd.to_numeric(grp[col], errors="coerce").dropna().values
            box_data_bmr.append(vals)
            box_labels_bmr.append(lbl)
            box_colors_bmr.append(color)
        if box_data_bmr:
            bp_bmr = ax_r1.boxplot(box_data_bmr, patch_artist=True,
                                medianprops=dict(color="black", linewidth=1.5),
                                flierprops=dict(marker=".", markersize=3, alpha=0.4))
            for patch, color in zip(bp_bmr["boxes"], box_colors_bmr):
                patch.set_facecolor(color)
                patch.set_alpha(0.65)
            ax_r1.set_xticklabels(box_labels_bmr, fontsize=9)
        ax_r1.axhline(0.0, color="green", linestyle="--", linewidth=0.8, alpha=0.7)
        ax_r1.set_title(f"Trace: {trace_name}\nRegret BMR distribution", fontsize=9)
        ax_r1.set_ylabel("Regret BMR")
        ax_r1.grid(True, alpha=0.3, axis="y")
        for i, vals in enumerate(box_data_bmr, start=1):
            med = float(np.nanmedian(vals))
            ax_r1.text(i, med, f" {med:.4f}", fontsize=7,
                       va="center", ha="left", color="black")

    plt.suptitle(
        f"Regret Analysis  |  {label}\n"
        "(Regret = chosen - oracle_best;  green line = 0 = perfect)",
        fontsize=10, y=1.01,
    )
    plt.tight_layout()
    fpath = os.path.join(out_dir, f"{label}_experiment_regret.png")
    plt.savefig(fpath, dpi=150, bbox_inches="tight")
    plt.close()
    print(f"  Saved: {fpath}")



def _plot_rank_analysis(pred_df, out_dir, label):
    """
    Rank analysis: for each window t, among all (K, sc, update_type) conditions,
    what rank does the ML-predicted config achieve?

    Outputs {label}_experiment_rank.png:
      Row 0: Rolling-20 mean rank over time
      Row 1: Histogram of rank_of_predicted (1 = best)
      Row 2: mr_gap_to_best distribution (how much MR penalty for wrong prediction)
    """
    if pred_df.empty:
        return
    need = {"rank_of_predicted", "pct_rank", "mr_gap_to_best"}
    if not need.issubset(pred_df.columns):
        return

    traces = pred_df["trace"].unique()
    n_tr   = len(traces)

    has_bmr_rank    = "rank_of_predicted_bmr"    in pred_df.columns
    has_pareto_rank = "rank_of_predicted_pareto" in pred_df.columns
    n_rows = (7 if (has_bmr_rank and has_pareto_rank)
              else (6 if has_pareto_rank
              else (5 if has_bmr_rank else 3)))

    fig, axes = plt.subplots(n_rows, n_tr,
                             figsize=(max(7, 6 * n_tr), 3.5 * n_rows),
                             squeeze=False)

    for col_i, trace_name in enumerate(traces):
        grp = pred_df[pred_df["trace"] == trace_name].sort_values("window")
        ws  = grp["window"].values

        rank_vals = pd.to_numeric(grp["rank_of_predicted"], errors="coerce")
        gap_vals  = pd.to_numeric(grp["mr_gap_to_best"],    errors="coerce")
        n_cond    = int(grp["n_conditions"].dropna().median()) if "n_conditions" in grp.columns else 1

        # ── Row 0: rolling mean rank ─────────────────────────────────────────
        ax0 = axes[0, col_i]
        roll_rank = rank_vals.rolling(20, min_periods=1).mean().values
        ax0.plot(ws, roll_rank, color="#1976D2", linewidth=1.5, label="ML rank MR (roll-20)")
        ax0.axhline(1.0, color="green", linestyle="--", linewidth=0.8, alpha=0.7, label="Oracle (rank 1)")
        ax0.axhline(n_cond / 2.0, color="gray",  linestyle=":",  linewidth=0.8, alpha=0.7, label="Random baseline")
        ax0.set_xlabel("Window t")
        ax0.set_ylabel("Rank (1=best)")
        ax0.set_ylim(bottom=0)
        ax0.legend(fontsize=8)
        ax0.grid(True, alpha=0.3)

        med_rank = float(rank_vals.dropna().median()) if rank_vals.notna().any() else float("nan")
        pct_rank_1 = float((rank_vals == 1).sum() / rank_vals.notna().sum()) if rank_vals.notna().sum() > 0 else float("nan")
        ax0.set_title(
            f"{trace_name}  |  median rank={med_rank:.1f}  "
            f"rank-1 rate={pct_rank_1:.1%}  (n_cond={n_cond})",
            fontsize=8,
        )

        # ── Row 1: histogram of rank ─────────────────────────────────────────
        ax1 = axes[1, col_i]
        rank_clean = rank_vals.dropna().astype(int).values
        if len(rank_clean) > 0:
            max_rank = int(rank_clean.max())
            bins = list(range(1, max_rank + 2))
            ax1.hist(rank_clean, bins=bins, align="left", color="#1976D2", alpha=0.75, edgecolor="white")
        ax1.set_title("Distribution of Predicted Config Rank (MR)", fontsize=9)
        ax1.set_xlabel("Rank by MR (1=best)")
        ax1.set_ylabel("Count")
        ax1.grid(True, alpha=0.3, axis="y")

        # ── Row 2: mr_gap_to_best histogram ─────────────────────────────────
        ax2 = axes[2, col_i]
        gap_clean = gap_vals.dropna().values
        if len(gap_clean) > 0:
            ax2.hist(gap_clean, bins=40, color="#F57C00", alpha=0.75, edgecolor="white")
            med_gap = float(np.median(gap_clean))
            p95_gap = float(np.percentile(gap_clean, 95))
            ax2.axvline(med_gap, color="red",  linestyle="--", linewidth=1.2,
                        label=f"median={med_gap:.4f}")
            ax2.axvline(p95_gap, color="gray", linestyle=":",  linewidth=1.0,
                        label=f"p95={p95_gap:.4f}")
            ax2.legend(fontsize=8)
        ax2.set_title("MR Gap to Oracle Best", fontsize=9)
        ax2.set_xlabel("MR(predicted) - MR(best)")
        ax2.set_ylabel("Count")
        ax2.grid(True, alpha=0.3, axis="y")

        if not has_bmr_rank:
            # No BMR rows — check for Pareto at rows 3+4
            if not has_pareto_rank:
                continue
            rank_par_vals = pd.to_numeric(grp["rank_of_predicted_pareto"], errors="coerce")
            gap_par_vals  = pd.to_numeric(grp["pareto_composite_gap"],     errors="coerce")
            ax3b = axes[3, col_i]
            roll_rank_par = rank_par_vals.rolling(20, min_periods=1).mean().values
            ax3b.plot(ws, roll_rank_par, color="#2E7D32", linewidth=1.5, label="ML rank Pareto (roll-20)")
            ax3b.axhline(1.0, color="green", linestyle="--", linewidth=0.8, alpha=0.7, label="Oracle (rank 1)")
            ax3b.axhline(n_cond / 2.0, color="gray", linestyle=":", linewidth=0.8, alpha=0.7)
            ax3b.set_xlabel("Window t"); ax3b.set_ylabel("Rank (1=best)")
            ax3b.set_ylim(bottom=0); ax3b.legend(fontsize=8); ax3b.grid(True, alpha=0.3)
            med_rp = float(rank_par_vals.dropna().median()) if rank_par_vals.notna().any() else float("nan")
            pct_rp = float((rank_par_vals == 1).sum() / rank_par_vals.notna().sum()) if rank_par_vals.notna().sum() > 0 else float("nan")
            ax3b.set_title(f"{trace_name}  |  Pareto rank: median={med_rp:.1f}  rank-1={pct_rp:.1%}", fontsize=8)
            ax4b = axes[4, col_i]
            gap_par_clean = gap_par_vals.dropna().values
            if len(gap_par_clean) > 0:
                ax4b.hist(gap_par_clean, bins=40, color="#2E7D32", alpha=0.75, edgecolor="white")
                med_gp = float(np.median(gap_par_clean))
                ax4b.axvline(med_gp, color="red", linestyle="--", linewidth=1.2, label=f"median={med_gp:.4f}")
                ax4b.legend(fontsize=8)
            ax4b.set_title("Pareto Composite Gap", fontsize=9)
            ax4b.set_xlabel("Composite(predicted) - Composite(best)")
            ax4b.set_ylabel("Count"); ax4b.grid(True, alpha=0.3, axis="y")
            continue

        # ── Row 3: rolling mean rank (BMR) ───────────────────────────────────
        rank_bmr_vals = pd.to_numeric(grp["rank_of_predicted_bmr"], errors="coerce")
        gap_bmr_vals  = pd.to_numeric(grp["bmr_gap_to_best"],       errors="coerce")

        ax3 = axes[3, col_i]
        roll_rank_bmr = rank_bmr_vals.rolling(20, min_periods=1).mean().values
        ax3.plot(ws, roll_rank_bmr, color="#7B1FA2", linewidth=1.5, label="ML rank BMR (roll-20)")
        ax3.axhline(1.0, color="green", linestyle="--", linewidth=0.8, alpha=0.7, label="Oracle (rank 1)")
        ax3.axhline(n_cond / 2.0, color="gray", linestyle=":", linewidth=0.8, alpha=0.7, label="Random baseline")
        ax3.set_xlabel("Window t")
        ax3.set_ylabel("Rank (1=best)")
        ax3.set_ylim(bottom=0)
        ax3.legend(fontsize=8)
        ax3.grid(True, alpha=0.3)
        med_rank_bmr   = float(rank_bmr_vals.dropna().median()) if rank_bmr_vals.notna().any() else float("nan")
        pct_rank_bmr_1 = float((rank_bmr_vals == 1).sum() / rank_bmr_vals.notna().sum()) if rank_bmr_vals.notna().sum() > 0 else float("nan")
        ax3.set_title(
            f"{trace_name}  |  BMR rank: median={med_rank_bmr:.1f}  "
            f"rank-1={pct_rank_bmr_1:.1%}  (n_cond={n_cond})",
            fontsize=8,
        )

        # ── Row 4: bmr_gap_to_best histogram ─────────────────────────────────
        ax4 = axes[4, col_i]
        gap_bmr_clean = gap_bmr_vals.dropna().values
        if len(gap_bmr_clean) > 0:
            ax4.hist(gap_bmr_clean, bins=40, color="#7B1FA2", alpha=0.75, edgecolor="white")
            med_gap_bmr = float(np.median(gap_bmr_clean))
            p95_gap_bmr = float(np.percentile(gap_bmr_clean, 95))
            ax4.axvline(med_gap_bmr, color="red", linestyle="--", linewidth=1.2,
                        label=f"median={med_gap_bmr:.4f}")
            ax4.axvline(p95_gap_bmr, color="gray", linestyle=":", linewidth=1.0,
                        label=f"p95={p95_gap_bmr:.4f}")
            ax4.legend(fontsize=8)
        ax4.set_title("BMR Gap to Oracle Best", fontsize=9)
        ax4.set_xlabel("BMR(predicted) - BMR(best)")
        ax4.set_ylabel("Count")
        ax4.grid(True, alpha=0.3, axis="y")

        if not has_pareto_rank:
            continue

        # ── Row 5: rolling mean rank (Pareto composite) ──────────────────────
        rank_par_vals = pd.to_numeric(grp["rank_of_predicted_pareto"], errors="coerce")
        gap_par_vals  = pd.to_numeric(grp["pareto_composite_gap"],     errors="coerce")

        ax5 = axes[5, col_i]
        roll_rank_par = rank_par_vals.rolling(20, min_periods=1).mean().values
        ax5.plot(ws, roll_rank_par, color="#2E7D32", linewidth=1.5, label="ML rank Pareto (roll-20)")
        ax5.axhline(1.0, color="green", linestyle="--", linewidth=0.8, alpha=0.7, label="Oracle (rank 1)")
        ax5.axhline(n_cond / 2.0, color="gray", linestyle=":", linewidth=0.8, alpha=0.7, label="Random baseline")
        ax5.set_xlabel("Window t")
        ax5.set_ylabel("Rank (1=best)")
        ax5.set_ylim(bottom=0)
        ax5.legend(fontsize=8)
        ax5.grid(True, alpha=0.3)
        med_rank_par   = float(rank_par_vals.dropna().median()) if rank_par_vals.notna().any() else float("nan")
        pct_rank_par_1 = float((rank_par_vals == 1).sum() / rank_par_vals.notna().sum()) if rank_par_vals.notna().sum() > 0 else float("nan")
        ax5.set_title(
            f"{trace_name}  |  Pareto rank: median={med_rank_par:.1f}  "
            f"rank-1={pct_rank_par_1:.1%}  (n_cond={n_cond})",
            fontsize=8,
        )

        # ── Row 6: pareto_composite_gap histogram ─────────────────────────────
        ax6 = axes[6, col_i]
        gap_par_clean = gap_par_vals.dropna().values
        if len(gap_par_clean) > 0:
            ax6.hist(gap_par_clean, bins=40, color="#2E7D32", alpha=0.75, edgecolor="white")
            med_gap_par = float(np.median(gap_par_clean))
            p95_gap_par = float(np.percentile(gap_par_clean, 95))
            ax6.axvline(med_gap_par, color="red", linestyle="--", linewidth=1.2,
                        label=f"median={med_gap_par:.4f}")
            ax6.axvline(p95_gap_par, color="gray", linestyle=":", linewidth=1.0,
                        label=f"p95={p95_gap_par:.4f}")
            ax6.legend(fontsize=8)
        ax6.set_title("Pareto Composite Gap to Oracle Best", fontsize=9)
        ax6.set_xlabel("Composite(predicted) - Composite(best)  [norm_MR + norm_BMR]")
        ax6.set_ylabel("Count")
        ax6.grid(True, alpha=0.3, axis="y")

    # ── Summary stats in suptitle ────────────────────────────────────────────
    all_rank = pd.to_numeric(pred_df["rank_of_predicted"], errors="coerce").dropna()
    all_gap  = pd.to_numeric(pred_df["mr_gap_to_best"],    errors="coerce").dropna()
    rank1_pct = float((all_rank == 1).sum() / len(all_rank)) if len(all_rank) > 0 else float("nan")
    med_gap_all = float(all_gap.median()) if len(all_gap) > 0 else float("nan")

    bmr_suffix = ""
    if has_bmr_rank:
        all_rank_bmr  = pd.to_numeric(pred_df["rank_of_predicted_bmr"], errors="coerce").dropna()
        all_gap_bmr   = pd.to_numeric(pred_df["bmr_gap_to_best"],       errors="coerce").dropna()
        rank1_bmr_pct = float((all_rank_bmr == 1).sum() / len(all_rank_bmr)) if len(all_rank_bmr) > 0 else float("nan")
        med_gap_bmr_all = float(all_gap_bmr.median()) if len(all_gap_bmr) > 0 else float("nan")
        bmr_suffix = (f"  |  BMR: median_rank={all_rank_bmr.median():.1f}  "
                      f"rank-1={rank1_bmr_pct:.1%}  median_BMR_gap={med_gap_bmr_all:.4f}")
    pareto_suffix = ""
    if has_pareto_rank:
        all_rank_par  = pd.to_numeric(pred_df["rank_of_predicted_pareto"], errors="coerce").dropna()
        all_gap_par   = pd.to_numeric(pred_df["pareto_composite_gap"],     errors="coerce").dropna()
        rank1_par_pct = float((all_rank_par == 1).sum() / len(all_rank_par)) if len(all_rank_par) > 0 else float("nan")
        med_gap_par_all = float(all_gap_par.median()) if len(all_gap_par) > 0 else float("nan")
        pareto_suffix = (f"  |  Pareto: median_rank={all_rank_par.median():.1f}  "
                         f"rank-1={rank1_par_pct:.1%}  median_gap={med_gap_par_all:.4f}")

    plt.suptitle(
        f"Rank Analysis  |  {label}\n"
        f"MR: median_rank={all_rank.median():.1f}  "
        f"rank-1={rank1_pct:.1%}  "
        f"median_MR_gap={med_gap_all:.4f}"
        + bmr_suffix + pareto_suffix,
        fontsize=10, y=1.01,
    )
    plt.tight_layout()
    fpath = os.path.join(out_dir, f"{label}_experiment_rank.png")
    plt.savefig(fpath, dpi=150, bbox_inches="tight")
    plt.close()
    print(f"  Saved: {fpath}")

